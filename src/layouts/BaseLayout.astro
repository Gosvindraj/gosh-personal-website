---
import Navbar from "../components/Navbar.astro";
import ChatBot from "../components/ChatBot";
import "@fontsource-variable/archivo/wdth.css";
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/jetbrains-mono/wght-italic.css";
import "@fontsource/instrument-serif";
import "@fontsource/instrument-serif/400-italic.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  hideFooter?: boolean;
  pageClass?: string;
}

const { title, description = "Gosvindraj's space on the internet. Projects, things I'm working on, and everything else that doesn't fit anywhere else.", hideFooter = false, pageClass = "" } = Astro.props;

const siteUrl = "https://gosvindraj.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}/og-image.png`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteUrl}/#person`,
    "name": "Gosvindraj",
    "alternateName": ["Gosvindraj Munusamy", "Gosh"],
    "url": siteUrl,
    "image": `${siteUrl}/og-image.png`,
    "sameAs": [
      "https://github.com/Gosvindraj",
      "https://www.linkedin.com/in/gosvindraj-m-3306b9280/",
      "https://www.instagram.com/gosv7ndraj/"
    ],
    "jobTitle": "Developer",
    "description": "Gosvindraj's space on the internet. Projects, things I'm working on, and everything else that doesn't fit anywhere else."
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    "name": "Gosvindraj",
    "url": siteUrl,
    "description": "Personal portfolio of Gosvindraj, developer and AI enthusiast.",
    "author": { "@id": `${siteUrl}/#person` }
  }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Gosvindraj" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="gosh. builds what's next. Gosvindraj's portfolio." />
    <meta property="og:site_name" content="Gosvindraj" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="gosh. builds what's next. Gosvindraj's portfolio." />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <!-- preloader: counts once per session, then wipes up -->
    <div id="preloader" transition:persist>
      <span id="preloader-count">000</span>
      <span id="preloader-tag">gosvindraj / portfolio</span>
      <div id="preloader-bar"></div>
    </div>

    <!-- custom cursor -->
    <div id="cursor-dot"  transition:persist></div>
    <div id="cursor-ring" transition:persist></div>

    <Navbar />
    <main class={pageClass}>
      <slot />
    </main>

    {!hideFooter && (
    <footer id="site-footer">
      <div class="foot-bottom">
        <span>&copy; {new Date().getFullYear()} gosvindraj</span>
        <div class="foot-socials">
          <a href="mailto:gosh@gosvindraj.com">email</a>
          <a href="https://github.com/Gosvindraj" target="_blank" rel="noopener">github</a>
          <a href="https://www.linkedin.com/in/gosvindraj-m-3306b9280/" target="_blank" rel="noopener">linkedin</a>
          <a href="https://www.instagram.com/gosv7ndraj/" target="_blank" rel="noopener">instagram</a>
        </div>
      </div>
    </footer>
    )}

    <!-- chatbot island: persists across page navigations -->
    <ChatBot client:load transition:persist />

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      gsap.registerPlugin(ScrollTrigger);

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      /* ── ScrollTrigger cleanup on page transitions ── */
      document.addEventListener("astro:before-swap", () => {
        ScrollTrigger.getAll().forEach((t) => t.kill());
      });
      document.addEventListener("astro:page-load", () => {
        ScrollTrigger.refresh();
      });

      /* re-measure once custom fonts finish loading: triggers created
         (or refreshed) while the display face is still the fallback
         end up with the wrong scroll range for anything sized off a
         big heading — most visibly the first .sec-ghost on a page,
         whose section starts right below the giant page-title h1 */
      if (document.fonts) {
        document.fonts.ready.then(() => ScrollTrigger.refresh());
      }

      /* ── shared reveal helper ─────────────────────
         any element with [data-reveal] rises in on scroll.
         optional data-reveal-delay (seconds). content stays
         visible without JS since hiding happens here. */
      function initReveals() {
        if (reduced) return;
        document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
          const delay = parseFloat(el.dataset.revealDelay ?? "0");
          gsap.fromTo(el,
            { opacity: 0, y: 26 },
            {
              opacity: 1, y: 0, duration: 0.7, delay, ease: "power3.out",
              scrollTrigger: { trigger: el, start: "top 88%", once: true },
            }
          );
        });
      }
      document.addEventListener("astro:page-load", initReveals);

      /* ── shared ghost helper ──────────────────────
         any .sec-ghost inside a .sec-ghosted section drifts
         sideways on scroll-scrub. purely decorative.
         range is pinned to one viewport height (the section
         entering view), not the section's own height — tall
         sections (like about's timeline) would otherwise smear
         the drift across way more scrolling than anyone actually
         does in there, reading as "stuck" instead of moving */
      function initGhosts() {
        if (reduced) return;
        document.querySelectorAll<HTMLElement>(".sec-ghost").forEach((ghost) => {
          // pop in once, like the rest of the section's [data-reveal]
          // content, instead of being fully visible on page load
          gsap.set(ghost, { opacity: 0 });

          const rect = ghost.parentElement!.getBoundingClientRect();
          const alreadyInView = rect.top < window.innerHeight * 0.85;

          if (alreadyInView) {
            // this section is already on screen at load — a
            // ScrollTrigger here would fire instantly (it's not
            // really a "scroll" reveal), so give it a fixed delay
            // instead, timed to land after the page's own entrance
            // animation has settled
            gsap.to(ghost, { opacity: 1, duration: 0.9, ease: "power3.out", delay: 1.1 });
          } else {
            gsap.to(ghost, {
              opacity: 1,
              duration: 0.9,
              ease: "power3.out",
              scrollTrigger: {
                trigger: ghost.parentElement,
                start: "top 85%",
                once: true,
              },
            });
          }

          gsap.fromTo(ghost,
            { xPercent: 3 },
            {
              xPercent: -5,
              ease: "none",
              scrollTrigger: {
                trigger: ghost.parentElement,
                start: "top bottom",
                end: "top top",
                scrub: 0.6,
              },
            }
          );
        });
      }
      document.addEventListener("astro:page-load", initGhosts);

      /* ── preloader ──────────────────────────────── */
      const preloader = document.getElementById("preloader");

      if (preloader) {
        if (sessionStorage.getItem("intro-seen") || reduced) {
          preloader.style.display = "none";
          sessionStorage.setItem("intro-seen", "1");
        } else {
          const bar     = document.getElementById("preloader-bar")!;
          const countEl = document.getElementById("preloader-count")!;
          document.body.style.overflow = "hidden";

          const counter = { val: 0 };

          gsap.timeline({
            onComplete: () => {
              preloader.style.display = "none";
              document.body.style.overflow = "";
              sessionStorage.setItem("intro-seen", "1");
            },
          })
            .to(bar, { width: "100%", duration: 1.1, ease: "power2.inOut" })
            .to(counter, {
              val: 100,
              duration: 1.1,
              ease: "power2.inOut",
              onUpdate() {
                countEl.textContent = Math.round(counter.val).toString().padStart(3, "0");
              },
            }, "<")
            .to({}, { duration: 0.15 })
            .to([countEl, "#preloader-tag", bar], { opacity: 0, duration: 0.25, ease: "power2.in" })
            .to(preloader, { yPercent: -100, duration: 0.65, ease: "expo.inOut" }, "-=0.05");
        }
      }

      /* ── cursor ─────────────────────────────────── */
      const dot  = document.getElementById("cursor-dot")!;
      const ring = document.getElementById("cursor-ring")!;

      let mouseX = 0, mouseY = 0;
      let ringX  = 0, ringY  = 0;

      gsap.set([dot, ring], { xPercent: -50, yPercent: -50 });

      document.addEventListener("mousemove", (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        gsap.set(dot, { x: mouseX, y: mouseY });
      });

      gsap.ticker.add(() => {
        ringX += (mouseX - ringX) * 0.14;
        ringY += (mouseY - ringY) * 0.14;
        gsap.set(ring, { x: ringX, y: ringY });
      });

      document.addEventListener("dragstart", (e) => e.preventDefault());

      /* click ripple */
      document.addEventListener("mousedown", (e) => {
        if (reduced) return;
        const ripple = document.createElement("div");
        ripple.className = "cursor-ripple";
        document.body.appendChild(ripple);
        gsap.set(ripple, { xPercent: -50, yPercent: -50, x: e.clientX, y: e.clientY, scale: 0.2, opacity: 0.9, rotation: 45 });
        gsap.to(ripple, {
          scale: 2.4,
          opacity: 0,
          rotation: 90,
          duration: 0.5,
          ease: "power2.out",
          onComplete: () => ripple.remove(),
        });
      });

      /* hover state rebinding after navigations */
      function bindCursorStates() {
        document.querySelectorAll("a, button, input, textarea, [data-cursor]").forEach((el) => {
          el.addEventListener("mouseenter", () => document.body.classList.add("cursor-hover"));
          el.addEventListener("mouseleave", () => document.body.classList.remove("cursor-hover"));
        });
      }

      bindCursorStates();
      document.addEventListener("astro:page-load", bindCursorStates);
    </script>
  </body>
</html>
