---
const links = [
  { href: "/about",    label: "about",    index: "01" },
  { href: "/projects", label: "projects", index: "02" },
  { href: "/blog",     label: "blog",     index: "03" },
  { href: "/contact",  label: "contact",  index: "04" },
];
---

<header id="site-nav" transition:persist>
  <a href="/" class="nav-brand" aria-label="Home">
    <img src="/logos/purple-text/mark-gosh-ligature-heavy-purple-text.svg" alt="gosh." width="92" height="33" />
  </a>

  <nav aria-label="Primary">
    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a href={link.href} data-nav-link>
            <sup>{link.index}</sup>{link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-overlay">menu</button>
</header>

<!-- full-screen menu: sibling of the header because its backdrop-filter
     would otherwise become the containing block for position: fixed -->
<div id="nav-overlay" aria-hidden="true" transition:persist="nav-overlay">
  <ul class="ov-links">
    {links.map((link) => (
      <li>
        <a href={link.href} data-nav-link>
          <sup>{link.index}</sup>{link.label}
        </a>
      </li>
    ))}
  </ul>
  <div class="ov-foot">
    <a href="mailto:gosh@gosvindraj.com">gosh@gosvindraj.com</a>
  </div>
</div>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* header persists across navigations, so bind once at module init
     and only refresh per-page state on astro:page-load */

  /* ── active link state ─────────────────────── */
  function syncActiveLinks() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]").forEach((a) => {
      const href = a.getAttribute("href") ?? "";
      a.classList.toggle("active", href !== "/" && path.startsWith(href));
    });
  }

  /* ── overlay menu ──────────────────────────── */
  /* toggle/overlay are re-queried on every use (never captured once
     as module-level consts) and every listener below is delegated
     to document instead of bound directly to these nodes. header
     and overlay are transition:persist, so this SHOULD be
     unnecessary — but persistence isn't 100% guaranteed on every
     transition (mobile memory pressure, rapid back-to-back
     navigation), and if it ever silently fails, a direct listener
     bound to a since-detached node goes dead with no way to
     recover, which reads to a visitor as "the menu button just
     stopped working". delegation means a stale reference can never
     be the failure mode. */
  let menuOpen = false;
  /* whether we've pushed a throwaway history entry for the open menu.
     it lets the OS/browser back action (android back button + back
     swipe, ios back swipe) pop that entry to CLOSE the menu instead
     of navigating away or leaving the site. */
  let pushedState = false;

  function openMenu() {
    const overlay = document.getElementById("nav-overlay");
    const toggle  = document.getElementById("nav-toggle");
    if (!overlay || !toggle) return;
    menuOpen = true;
    if (!pushedState) {
      history.pushState({ navMenuOpen: true }, "");
      pushedState = true;
    }
    gsap.killTweensOf(overlay);
    overlay.style.display = "flex";
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    toggle.textContent = "close";
    document.body.style.overflow = "hidden";
    /* hides the chatbot launcher (higher z-index than the overlay)
       while the full-screen menu is open — see global.css */
    document.body.classList.add("nav-open");
    const items = overlay.querySelectorAll(".ov-links a");
    if (reduced) {
      gsap.set(overlay, { opacity: 1 });
      gsap.set(items, { y: "0%" });
      return;
    }
    gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.25, ease: "power2.out" });
    gsap.killTweensOf(items);
    gsap.fromTo(items,
      { y: "110%" },
      { y: "0%", duration: 0.55, stagger: 0.06, ease: "power4.out", delay: 0.08 }
    );
  }

  /* viaPop:     close came from a popstate (back gesture) — the throwaway
                 entry is already gone, don't touch history.
     navigating: close came from tapping a nav link (or a page load) — a
                 real navigation is about to add its own history entry, so
                 don't call history.back() here or it cancels that nav. */
  function closeMenu(instant = false, viaPop = false, navigating = false) {
    const overlay = document.getElementById("nav-overlay");
    const toggle  = document.getElementById("nav-toggle");
    if (!overlay || !toggle) return;
    menuOpen = false;
    toggle.setAttribute("aria-expanded", "false");
    toggle.textContent = "menu";
    document.body.style.overflow = "";
    document.body.classList.remove("nav-open");
    overlay.setAttribute("aria-hidden", "true");
    /* only a deliberate dismiss (toggle / Escape) unwinds the throwaway
       entry. the back gesture already popped it; a link tap lets the
       real navigation supersede it. */
    if (pushedState) {
      pushedState = false;
      if (!viaPop && !navigating) history.back();
    }
    gsap.killTweensOf(overlay);
    if (reduced || instant) {
      overlay.style.display = "none";
      gsap.set(overlay, { opacity: 1 });
      return;
    }
    gsap.to(overlay, {
      opacity: 0, duration: 0.22, ease: "power2.in",
      onComplete: () => { overlay.style.display = "none"; gsap.set(overlay, { opacity: 1 }); },
    });
  }

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target.closest("#nav-toggle")) {
      menuOpen ? closeMenu() : openMenu();
    } else if (target.closest("#nav-overlay a")) {
      closeMenu(true, false, true); // navigating: let the link's nav proceed
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMenu();
  });

  /* back gesture / back button while the menu is open: the throwaway
     entry we pushed on open has just been popped, so close the menu
     and stay on the current page (don't navigate away). */
  window.addEventListener("popstate", () => {
    if (menuOpen) closeMenu(true, true);
  });

  /* ── desktop link roll hover ───────────────── */
  document.querySelectorAll<HTMLElement>(".nav-links a").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      if (reduced) return;
      gsap.fromTo(link, { y: 0 }, { y: -2, duration: 0.18, yoyo: true, repeat: 1, ease: "power2.out" });
    });
  });

  syncActiveLinks();
  document.addEventListener("astro:page-load", () => {
    syncActiveLinks();
    /* unconditional + instant: guarantees a clean, fully-reset menu
       state on every single page load, regardless of what state
       (or mid-animation state) the previous page left things in.
       navigating=true: the page already changed, so don't unwind
       history here. */
    closeMenu(true, false, true);
  });
</script>
