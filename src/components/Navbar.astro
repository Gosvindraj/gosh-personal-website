---
const links = [
  { href: "/about",    label: "about",    index: "01" },
  { href: "/projects", label: "projects", index: "02" },
  { href: "/blog",     label: "blog",     index: "03" },
  { href: "/contact",  label: "contact",  index: "04" },
];
---

<header id="site-nav" transition:persist>
  <a href="/" class="nav-brand" aria-label="Home">
    <img src="/logos/purple-text/mark-gosh-ligature-heavy-purple-text.svg" alt="gosh." width="92" height="33" />
  </a>

  <nav aria-label="Primary">
    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a href={link.href} data-nav-link>
            <sup>{link.index}</sup>{link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-overlay">menu</button>
</header>

<!-- full-screen menu: sibling of the header because its backdrop-filter
     would otherwise become the containing block for position: fixed -->
<div id="nav-overlay" aria-hidden="true" transition:persist="nav-overlay">
  <ul class="ov-links">
    {links.map((link) => (
      <li>
        <a href={link.href} data-nav-link>
          <sup>{link.index}</sup>{link.label}
        </a>
      </li>
    ))}
  </ul>
  <div class="ov-foot">
    <a href="mailto:gosh@gosvindraj.com">gosh@gosvindraj.com</a>
  </div>
</div>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* header persists across navigations, so bind once at module init
     and only refresh per-page state on astro:page-load */

  /* ── active link state ─────────────────────── */
  function syncActiveLinks() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]").forEach((a) => {
      const href = a.getAttribute("href") ?? "";
      a.classList.toggle("active", href !== "/" && path.startsWith(href));
    });
  }

  /* ── overlay menu ──────────────────────────── */
  const toggle  = document.getElementById("nav-toggle");
  const overlay = document.getElementById("nav-overlay");
  let menuOpen  = false;

  function openMenu() {
    if (!overlay || !toggle) return;
    menuOpen = true;
    overlay.style.display = "flex";
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    toggle.textContent = "close";
    document.body.style.overflow = "hidden";
    const items = overlay.querySelectorAll(".ov-links a");
    if (reduced) {
      gsap.set(items, { y: "0%" });
      return;
    }
    gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.25, ease: "power2.out" });
    gsap.fromTo(items,
      { y: "110%" },
      { y: "0%", duration: 0.55, stagger: 0.06, ease: "power4.out", delay: 0.08 }
    );
  }

  function closeMenu() {
    if (!overlay || !toggle || !menuOpen) return;
    menuOpen = false;
    toggle.setAttribute("aria-expanded", "false");
    toggle.textContent = "menu";
    document.body.style.overflow = "";
    overlay.setAttribute("aria-hidden", "true");
    if (reduced) {
      overlay.style.display = "none";
      return;
    }
    gsap.to(overlay, {
      opacity: 0, duration: 0.22, ease: "power2.in",
      onComplete: () => { overlay.style.display = "none"; gsap.set(overlay, { opacity: 1 }); },
    });
  }

  toggle?.addEventListener("click", () => (menuOpen ? closeMenu() : openMenu()));

  overlay?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMenu();
  });

  /* ── desktop link roll hover ───────────────── */
  document.querySelectorAll<HTMLElement>(".nav-links a").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      if (reduced) return;
      gsap.fromTo(link, { y: 0 }, { y: -2, duration: 0.18, yoyo: true, repeat: 1, ease: "power2.out" });
    });
  });

  syncActiveLinks();
  document.addEventListener("astro:page-load", () => {
    syncActiveLinks();
    closeMenu();
  });
</script>
