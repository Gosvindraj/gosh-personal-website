---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
}

function readMinutes(body: string | undefined) {
  const words = (body ?? "").trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}
---
<BaseLayout title="Gosvindraj | Blog" description="Opinions, observations, and things I'm working through. Written by hand, no AI.">

  <section id="blog-head">
    <div class="bh-top">
      <span class="m-label"><span class="lb">[</span> writing <span class="lb">/</span> unfiltered <span class="lb">]</span></span>
      <span class="m-label">{posts.length} {posts.length === 1 ? "entry" : "entries"}</span>
    </div>
    <div class="bh-title-row">
      <h1 class="bh-display display">
        <span class="line-mask"><span class="line">blog<span class="acid">.</span></span></span>
      </h1>
      <p class="bh-aside m-note">brain dumps, unfiltered.</p>
    </div>
    <p class="bh-sub">
      opinions, observations, things i'm figuring out. written by me,
      not AI, so expect imperfections. that's the point.
    </p>
  </section>

  <section class="sec sec-ghosted" id="blog-list">
    <span class="sec-ghost display" aria-hidden="true">entries</span>
    <div class="post-list">
      {posts.map((post, i) => (
        <a href={`/blog/${post.id}`} class="post-row" data-reveal>
          <div class="post-meta">
            <span class="post-num">{String(posts.length - i).padStart(2, "0")}</span>
            <span class="post-date">{formatDate(post.data.date)}</span>
            <span class="post-read">{readMinutes(post.body)} min read</span>
            {(post.data.tags ?? []).filter(Boolean).map((tag: string) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
          <div class="post-main">
            <h2 class="post-title">{post.data.title.toLowerCase()}</h2>
            {post.data.description && <p class="post-desc">{post.data.description}</p>}
          </div>
          <span class="post-arrow" aria-hidden="true">&#8599;</span>
        </a>
      ))}

      <div class="post-coming" data-reveal>
        <span class="m-label"><span class="lb">[</span> {String(posts.length + 1).padStart(2, "0")} <span class="lb">/</span> compiling <span class="lb">]</span></span>
        <span class="post-coming-note m-note">the next brain dump has no ETA. that's the charm.</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  #blog-head {
    padding: clamp(2rem, 6vh, 3.5rem) var(--gutter) clamp(2rem, 5vh, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3.5vh, 2rem);
  }

  .bh-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  /* drop the second (note) line on narrow screens instead of
     stacking or wrapping — the bracketed tag alone is enough */
  @media (max-width: 480px) {
    .bh-top > :last-child { display: none; }
  }

  /* title + margin-note pair: the page name at a human scale with a
     serif aside beside it, instead of a full-width tagline */
  .bh-title-row {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 2.5vw, 2rem);
    flex-wrap: wrap;
  }

  .bh-display { font-size: clamp(2.4rem, 5.5vw, 4.2rem); }

  /* typography comes from the shared .m-note code-comment utility */

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line { display: block; }

  .bh-sub {
    max-width: 48ch;
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    color: var(--dim);
    line-height: 1.85;
  }

  #blog-list {
    padding-top: 0;
    border-top: none;
    min-height: 30vh;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .post-row {
    display: grid;
    grid-template-columns: minmax(8rem, 13rem) 1fr 3rem;
    gap: 2rem;
    align-items: start;
    padding: clamp(1.6rem, 4vw, 2.5rem) 0.5rem;
    border-bottom: 1px solid var(--line);
    transition: background 0.25s ease, padding-left 0.25s ease;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.35em;
  }

  .post-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--acid);
    transition: color 0.25s ease;
  }

  .post-date,
  .post-read {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
    transition: color 0.25s ease;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--acid);
    transition: color 0.25s ease;
  }

  .post-main {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .post-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: clamp(1.4rem, 4vw, 2.6rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ink);
    transition: color 0.25s ease;
  }

  .post-desc {
    max-width: 60ch;
    font-size: 0.85rem;
    color: var(--dim);
    line-height: 1.7;
    transition: color 0.25s ease;
  }

  .post-arrow {
    font-size: 1.3rem;
    color: var(--faint);
    justify-self: end;
    padding-top: 0.35em;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .post-row:hover { background: var(--acid); padding-left: 1.25rem; }
  .post-row:hover .post-title,
  .post-row:hover .post-desc,
  .post-row:hover .post-date,
  .post-row:hover .post-read,
  .post-row:hover .post-num,
  .post-row:hover .post-tag { color: #0c0c0a; }
  .post-row:hover .post-arrow { color: #0c0c0a; transform: translate(3px, -3px); }

  /* non-interactive trailing row acknowledging the queue */
  .post-coming {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding: clamp(1.4rem, 3.5vw, 2rem) 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  .post-coming-note { color: var(--faint); }

  @media (max-width: 700px) {
    .post-row { grid-template-columns: 1fr 2.5rem; }
    .post-meta {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: baseline;
      gap: 0.9rem;
      padding-top: 0;
    }
    /* explicit column too: a row-only placement gets auto-placed
       before .post-main (which has no explicit position at all),
       so it was grabbing the wide 1fr column and squeezing the
       title into this 2.5rem one instead */
    .post-main  { grid-column: 1; }
    .post-arrow { grid-row: 2; grid-column: 2; }
  }
</style>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initBlogHead() {
    const head = document.getElementById("blog-head");
    if (!head || reduced) return;

    const lines = head.querySelectorAll<HTMLElement>(".line");
    const top   = head.querySelector<HTMLElement>(".bh-top");
    const sub   = head.querySelectorAll<HTMLElement>(".bh-aside, .bh-sub");

    gsap.set(top, { opacity: 0 });
    gsap.set(sub, { opacity: 0, y: 20 });
    gsap.set(lines, { yPercent: 110 });

    gsap.timeline({ delay: 0.15 })
      .to(lines, { yPercent: 0, duration: 0.85, stagger: 0.12, ease: "power4.out" })
      .to(sub, { opacity: 1, y: 0, duration: 0.55, ease: "power3.out" }, "-=0.4")
      .to(top, { opacity: 1, duration: 0.5, ease: "power2.out" }, "-=0.3");
  }

  document.addEventListener("astro:page-load", initBlogHead);
</script>
