---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry("blog", slug!);
if (!post) return Astro.redirect("/blog");

const { Content } = await render(post);

/* reading stats from the raw markdown source */
const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const minutes = Math.max(1, Math.round(words / 200));

/* older / newer neighbours for the end-matter navigation */
const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const postIndex = allPosts.findIndex((p) => p.id === post.id);
const newer = postIndex > 0 ? allPosts[postIndex - 1] : null;
const older = postIndex < allPosts.length - 1 ? allPosts[postIndex + 1] : null;
const entryNum = String(allPosts.length - postIndex).padStart(2, "0");

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }).toLowerCase();
}

const siteUrl = "https://gosvindraj.com";
const postUrl = `${siteUrl}/blog/${post.id}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description ?? "",
  "url": postUrl,
  "datePublished": post.data.date.toISOString(),
  "author": { "@id": `${siteUrl}/#person` },
  "publisher": { "@id": `${siteUrl}/#person` },
  "mainEntityOfPage": { "@type": "WebPage", "@id": postUrl },
};

const tags = (post.data.tags ?? []).filter(Boolean);
---
<BaseLayout title={`Gosvindraj | ${post.data.title}`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- acid reading-progress line, pinned under the navbar -->
  <div id="read-progress" aria-hidden="true"></div>

  <article id="post">
    <div class="post-inner">
      <header class="post-header">
        <a href="/blog" class="back-link m-label">&larr; all entries</a>

        <div class="post-meta m-label">
          <span class="hl">entry {entryNum}</span>
          <span class="lb">/</span>
          <span class="post-date-full">{formatDate(post.data.date)}</span>
          <span class="post-date-short">{formatDateShort(post.data.date)}</span>
          {tags.map((tag: string) => <span class="hl">{tag}</span>)}
          <span class="lb">/</span>
          <span>{minutes} min read</span>
        </div>

        <h1 class="post-title display">{post.data.title.toLowerCase()}</h1>
        {post.data.description && <p class="post-desc">{post.data.description}</p>}
      </header>

      <div class="post-body">
        <Content />
      </div>

      <footer class="post-foot">
        <div class="post-end m-label">
          <span class="pe-line" aria-hidden="true"></span>
          <span><span class="lb">[</span> end of entry <span class="lb">]</span></span>
          <span class="pe-line" aria-hidden="true"></span>
        </div>

        <nav class="post-nav" aria-label="Other entries">
          {newer && (
            <a href={`/blog/${newer.id}`} class="pn-row">
              <span class="pn-label m-label">newer</span>
              <span class="pn-title">{newer.data.title.toLowerCase()}</span>
              <span class="pn-arrow" aria-hidden="true">&#8599;</span>
            </a>
          )}
          {older && (
            <a href={`/blog/${older.id}`} class="pn-row">
              <span class="pn-label m-label">older</span>
              <span class="pn-title">{older.data.title.toLowerCase()}</span>
              <span class="pn-arrow" aria-hidden="true">&#8599;</span>
            </a>
          )}
          <a href="/blog" class="pn-row">
            <span class="pn-label m-label">index</span>
            <span class="pn-title">all entries</span>
            <span class="pn-arrow" aria-hidden="true">&#8599;</span>
          </a>
        </nav>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  /* acid line under the navbar filling as you read (JS scrub) */
  #read-progress {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--acid);
    transform: scaleX(0);
    transform-origin: left;
    z-index: 90;
    pointer-events: none;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    #read-progress { display: none; }
  }

  #post {
    min-height: calc(100dvh - var(--nav-height));
    padding: clamp(2rem, 6vh, 4rem) var(--gutter) clamp(3rem, 8vh, 5rem);
  }

  .post-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.5rem;
  }

  .back-link {
    align-self: flex-start;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--acid); }

  .post-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* full date on desktop, short date on mobile — keeps the whole
     meta row on one line instead of wrapping */
  .post-date-short { display: none; }

  @media (max-width: 480px) {
    .post-date-full  { display: none; }
    .post-date-short { display: inline; }
    .post-meta { gap: 0.6rem; flex-wrap: nowrap; overflow-x: auto; }
  }

  .post-title {
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .post-desc {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: var(--dim);
    line-height: 1.6;
  }

  .post-body {
    font-size: 0.95rem;
    color: var(--ink);
    line-height: 1.95;
  }

  .post-body :global(p)  { margin-bottom: 1.5rem; color: var(--dim); }
  .post-body :global(strong) { color: var(--ink); }
  .post-body :global(em) { font-family: var(--font-serif); font-size: 1.05em; color: var(--dim); }
  .post-body :global(h2) {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
    margin: 2.75rem 0 1rem;
  }
  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
    margin: 2.25rem 0 0.75rem;
  }
  .post-body :global(a) {
    color: var(--acid);
    border-bottom: 1px solid rgba(155, 109, 206, 0.4);
    transition: border-color 0.2s;
  }
  .post-body :global(a:hover) { border-color: var(--acid); }
  .post-body :global(ul),
  .post-body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.5rem; color: var(--dim); }
  .post-body :global(li) { margin-bottom: 0.45rem; }
  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.12em 0.4em;
    color: var(--acid);
  }
  .post-body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .post-body :global(pre code) { background: none; border: none; padding: 0; color: var(--ink); }
  .post-body :global(blockquote) {
    border-left: 2px solid var(--acid);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1em;
    color: var(--dim);
  }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5rem 0; }

  .post-foot {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* [ end of entry ] marker between two hairlines */
  .post-end {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .pe-line {
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  /* older / newer / index rows, with the site's invert hover */
  .post-nav {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .pn-row {
    display: grid;
    grid-template-columns: 4rem 1fr 2rem;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.1rem 0.5rem;
    border-bottom: 1px solid var(--line);
    transition: background 0.25s ease, padding-left 0.25s ease;
  }

  .pn-label { transition: color 0.25s ease; }

  .pn-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 600;
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
    transition: color 0.25s ease;
  }

  .pn-arrow {
    font-size: 1.1rem;
    color: var(--faint);
    justify-self: end;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .pn-row:hover { background: var(--acid); padding-left: 1.1rem; }
  .pn-row:hover .pn-title,
  .pn-row:hover .pn-label { color: var(--bg); }
  .pn-row:hover .pn-arrow { color: var(--bg); transform: translate(3px, -3px); }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initPost() {
    const inner = document.querySelector<HTMLElement>(".post-inner");
    if (!inner || reduced) return;
    gsap.fromTo(inner, { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.65, ease: "power3.out", delay: 0.1 });
  }

  /* reading progress: fills as the article body scrolls past */
  function initProgress() {
    const bar  = document.getElementById("read-progress");
    const body = document.querySelector<HTMLElement>(".post-body");
    if (!bar || !body || reduced) return;

    gsap.fromTo(bar,
      { scaleX: 0 },
      {
        scaleX: 1,
        ease: "none",
        scrollTrigger: {
          trigger: body,
          start: "top 25%",
          end: "bottom 75%",
          scrub: 0.4,
        },
      }
    );
  }

  document.addEventListener("astro:page-load", initPost);
  document.addEventListener("astro:page-load", initProgress);
</script>
