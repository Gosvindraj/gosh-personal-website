---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry("blog", slug!);
if (!post) return Astro.redirect("/blog");

const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
}

const siteUrl = "https://gosvindraj.com";
const postUrl = `${siteUrl}/blog/${post.id}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description ?? "",
  "url": postUrl,
  "datePublished": post.data.date.toISOString(),
  "author": { "@id": `${siteUrl}/#person` },
  "publisher": { "@id": `${siteUrl}/#person` },
  "mainEntityOfPage": { "@type": "WebPage", "@id": postUrl },
};

const tags = (post.data.tags ?? []).filter(Boolean);
---
<BaseLayout title={`Gosvindraj | ${post.data.title}`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <article id="post">
    <div class="post-inner">
      <header class="post-header">
        <a href="/blog" class="back-link m-label">&larr; all posts</a>

        <div class="post-meta m-label">
          <span>{formatDate(post.data.date)}</span>
          {tags.map((tag: string) => <span class="hl">{tag}</span>)}
          <span class="lb">/</span>
          <span>written by hand, no ai</span>
        </div>

        <h1 class="post-title display">{post.data.title.toLowerCase()}</h1>
        {post.data.description && <p class="post-desc">{post.data.description}</p>}
      </header>

      <div class="post-body">
        <Content />
      </div>

      <footer class="post-foot">
        <a href="/blog" class="btn-line">&larr; back to all posts</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  #post {
    min-height: calc(100vh - var(--nav-height));
    padding: clamp(2rem, 6vh, 4rem) var(--gutter) clamp(3rem, 8vh, 5rem);
  }

  .post-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.5rem;
  }

  .back-link {
    align-self: flex-start;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--acid); }

  .post-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .post-desc {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: var(--dim);
    line-height: 1.6;
  }

  .post-body {
    font-size: 0.95rem;
    color: var(--ink);
    line-height: 1.95;
  }

  .post-body :global(p)  { margin-bottom: 1.5rem; color: var(--dim); }
  .post-body :global(strong) { color: var(--ink); }
  .post-body :global(em) { font-family: var(--font-serif); font-size: 1.05em; color: var(--dim); }
  .post-body :global(h2) {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
    margin: 2.75rem 0 1rem;
  }
  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
    margin: 2.25rem 0 0.75rem;
  }
  .post-body :global(a) {
    color: var(--acid);
    border-bottom: 1px solid rgba(155, 109, 206, 0.4);
    transition: border-color 0.2s;
  }
  .post-body :global(a:hover) { border-color: var(--acid); }
  .post-body :global(ul),
  .post-body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.5rem; color: var(--dim); }
  .post-body :global(li) { margin-bottom: 0.45rem; }
  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.12em 0.4em;
    color: var(--acid);
  }
  .post-body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .post-body :global(pre code) { background: none; border: none; padding: 0; color: var(--ink); }
  .post-body :global(blockquote) {
    border-left: 2px solid var(--acid);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1em;
    color: var(--dim);
  }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5rem 0; }

  .post-foot {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
</style>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initPost() {
    const inner = document.querySelector<HTMLElement>(".post-inner");
    if (!inner || reduced) return;
    gsap.fromTo(inner, { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.65, ease: "power3.out", delay: 0.1 });
  }

  document.addEventListener("astro:page-load", initPost);
</script>
