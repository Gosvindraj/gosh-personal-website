---
import BaseLayout from "../layouts/BaseLayout.astro";

const botUrl = "https://t.me/bayarakuwoi_bot";
const botRepoUrl = "https://github.com/Gosvindraj/bill-splitter-bot";

const shots = [
  { src: "/bill-splitter/scan.png", label: "01 / scan a receipt", alt: "Bill Splitter scan screen, ready to photograph a receipt" },
  { src: "/bill-splitter/bill-detail.png", label: "02 / ai reads every line", alt: "An itemised receipt the app read from a photo, every line editable" },
  { src: "/bill-splitter/split.png", label: "03 / split it your way", alt: "The split screen with even, custom, and item-by-item options" },
  { src: "/bill-splitter/settle.png", label: "04 / settle up", alt: "The settle-up screen showing who owes who across the trip" },
  { src: "/bill-splitter/trip.png", label: "05 / group bills into trips", alt: "A trip grouping several bills together" },
  { src: "/bill-splitter/home.png", label: "06 / everything, at a glance", alt: "The home screen listing recent bills and trips" },
];

const steps = [
  {
    n: "01",
    title: "scan",
    body: "snap a photo of the receipt. a vision model (grok) reads every line item, the price, the quantity, and the tax, then hands you an editable draft instead of a blank form.",
  },
  {
    n: "02",
    title: "split",
    body: "even, custom percentages, or item by item, so the person who didn't order the wagyu doesn't pay for the wagyu.",
  },
  {
    n: "03",
    title: "settle",
    body: "one screen shows exactly who owes who, minimised across every bill in a trip. tap a debt as paid and it's done.",
  },
  {
    n: "04",
    title: "remember",
    body: "bills and trips sync to a real backend behind real accounts, so the data survives longer than the group chat does.",
  },
];

---
<BaseLayout
  title="Gosvindraj | Bill Splitter"
  description="A React Native + Expo app that reads receipt photos with AI, splits them however the group needs, and settles who owes who across a whole trip of bills."
>
  <section id="project-billsplit">
    <div class="project-inner">

      <div class="project-header" data-reveal>
        <span class="m-label"><span class="lb">[</span> project <span class="hl">01</span> <span class="lb">]</span></span>
        <h1 class="project-title display">bill<br />splitter<span class="serif acid">.</span></h1>
        <p class="project-desc">
          a mobile app for the who-owes-who problem: snap one receipt for an
          itemised split, or bundle a whole trip's worth of bills and settle
          everyone up across all of them. built with react native and expo,
          backed by supabase, with grok doing the actual reading.
        </p>
        <p class="project-note m-note">
          not on the app store. still lives in an expo dev build on my phone,
          which felt honest enough to say outright.
        </p>
        <a href="/projects" class="back-link m-label">&larr; all projects</a>
      </div>

      <div class="bill-wrap" data-reveal data-reveal-delay="0.15">
        <div class="filmstrip">
          {shots.map((s) => (
            <figure class="shot-card">
              <div class="shot-frame">
                <img src={s.src} alt={s.alt} loading="lazy" />
              </div>
              <figcaption class="m-label shot-cap">{s.label}</figcaption>
            </figure>
          ))}
          <figure class="shot-card">
            <div class="shot-frame note-frame">
              <div class="note-top">
                <p class="note-title display">before<br />the app<span class="serif acid">.</span></p>
                <p class="note-body m-note">
                  the same problem, solved first with <a href={botUrl} target="_blank" rel="noopener noreferrer">@bayarakuwoi_bot</a>.
                  it's locked to just me now, but the code's still worth a look.
                </p>
              </div>
              <a href={botRepoUrl} target="_blank" rel="noopener noreferrer" class="btn-solid btn-solid-invert note-link">read the code <span aria-hidden="true">&#8599;</span></a>
            </div>
            <figcaption class="m-label shot-cap">07 / before the app</figcaption>
          </figure>
        </div>
      </div>

    </div>
  </section>

  <section class="sec sec-ghosted" id="billsplit-how">
    <span class="sec-ghost display" aria-hidden="true">how</span>
    <div class="sec-head" data-reveal>
      <span class="m-label"><span class="lb">[</span> how <span class="lb">/</span> it works <span class="lb">]</span></span>
      <span class="m-label">four steps, no spreadsheet</span>
    </div>
    <div class="steps-list">
      {steps.map((s) => (
        <div class="step-row" data-reveal>
          <span class="step-n">{s.n}</span>
          <div class="step-main">
            <span class="step-title">{s.title}</span>
            <p class="step-body">{s.body}</p>
          </div>
        </div>
      ))}
    </div>
    <a href="/projects" class="back-link back-link-bottom m-label" data-reveal>&larr; all projects</a>
  </section>

</BaseLayout>

<style>
  /* ── hero shell (mirrors the other project pages) ──────────── */
  #project-billsplit {
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: clamp(2.5rem, 6vh, 4rem) var(--gutter);
  }

  .project-inner {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: clamp(3rem, 7vw, 6rem);
  }

  .project-header {
    flex: 0 0 320px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .project-title { font-size: clamp(2.3rem, 5.2vw, 4rem); }

  .project-desc {
    font-size: 0.9rem;
    color: var(--dim);
    line-height: 1.85;
  }

  .project-note {
    padding-top: 0.25rem;
    border-top: 1px solid var(--line);
  }

  .back-link {
    align-self: flex-start;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--acid); }

  /* ── filmstrip ──────────────────────────────────────────────── */
  .bill-wrap {
    flex: 1;
    min-width: 0;
  }

  .filmstrip {
    display: flex;
    gap: 1.1rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    padding-bottom: 0.75rem;
    /* purple scrollbar matching the site's global (vertical) one */
    scrollbar-width: thin;
    scrollbar-color: rgba(155, 109, 206, 0.3) transparent;
  }

  /* click-and-drag scrolling, see the script below — snap gets in the
     way of a held drag mid-gesture so it's suspended while dragging */
  .filmstrip.dragging {
    scroll-snap-type: none;
    user-select: none;
  }

  .filmstrip::-webkit-scrollbar { height: 6px; }
  .filmstrip::-webkit-scrollbar-track { background: transparent; }
  .filmstrip::-webkit-scrollbar-thumb { background: rgba(155, 109, 206, 0.3); }
  .filmstrip::-webkit-scrollbar-thumb:hover { background: rgba(155, 109, 206, 0.55); }

  .shot-card {
    flex: 0 0 auto;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: clamp(150px, 20vw, 190px);
    /* lets .note-link size itself off this card's real rendered width
       (cqw) instead of guessing per-breakpoint against the viewport */
    container-type: inline-size;
  }

  .shot-frame {
    aspect-ratio: 430 / 932;
    background: var(--surface);
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shot-cap { color: var(--faint); letter-spacing: 0.14em; }

  /* the 7th "card": not a screenshot, so the frame swaps to a text
     blurb about the earlier telegram-bot prototype, same footprint
     as the image cards around it. a bold title (the same pattern as
     the page's own project-title) gives it an anchor of its own,
     since it otherwise reads as empty next to six colourful shots. */
  .note-frame {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.1rem;
    border-color: rgba(155, 109, 206, 0.4);
  }

  .note-top {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .note-title {
    font-size: clamp(1.15rem, 2.6vw, 1.4rem);
    line-height: 1.1;
  }

  .note-body {
    font-size: 0.74rem;
    line-height: 1.6;
  }

  .note-body a {
    color: var(--acid);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .note-link {
    align-self: center;
    /* scales with the card's own width (container query units), not
       the viewport, so it grows as large as the card allows at every
       breakpoint without ever risking a wrap or clip */
    font-size: 5.5cqw;
    letter-spacing: 0.1em;
    gap: 0.3rem;
    padding: 0.5rem 0.75rem;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .project-inner { flex-direction: column; gap: 2.5rem; }
    .project-header { flex: none; position: static; }
    .bill-wrap { width: 100%; }
  }

  /* ── how it works ───────────────────────────────────────────── */
  .steps-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .step-row {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 2rem;
    padding: clamp(1.5rem, 3.5vw, 2.25rem) 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  /* a second way back once you've scrolled through "how it works" —
     the sticky header above only tracks the hero, not this section,
     so re-scrolling to the top to leave felt like a dead end */
  .back-link-bottom {
    display: inline-block;
    margin-top: 2rem;
  }

  .step-n {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    padding-top: 0.3em;
  }

  .step-main {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .step-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
  }

  .step-body {
    max-width: 62ch;
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.8;
  }

  @media (max-width: 700px) {
    .step-row { grid-template-columns: 2.5rem 1fr; }
  }
</style>

<script>
  /* click-and-hold + swipe scrolling for the filmstrip. touch already
     scrolls natively, so mouse/pen pointers only. */
  function initFilmstripDrag() {
    const strip = document.querySelector<HTMLElement>(".filmstrip");
    if (!strip) return;

    let down = false;
    let dragging = false;
    let moved = false;
    let startX = 0;
    let startScroll = 0;

    strip.addEventListener("pointerdown", (e) => {
      if (e.pointerType === "touch" || e.button !== 0) return;
      down = true;
      dragging = false;
      moved = false;
      startX = e.clientX;
      startScroll = strip.scrollLeft;
    });

    strip.addEventListener("pointermove", (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      // only start capturing/scrolling once real movement happens —
      // capturing on every plain click retargets its mouseup/click to
      // the strip instead of the link under the cursor, silently
      // killing clicks on links inside the strip
      if (!dragging && Math.abs(dx) > 4) {
        dragging = true;
        moved = true;
        strip.classList.add("dragging");
        strip.setPointerCapture(e.pointerId);
      }
      if (dragging) strip.scrollLeft = startScroll - dx;
    });

    const stop = () => {
      down = false;
      dragging = false;
      strip.classList.remove("dragging");
    };
    strip.addEventListener("pointerup", stop);
    strip.addEventListener("pointercancel", stop);

    // a link inside the strip (the note card) shouldn't fire on drag-release
    strip.addEventListener(
      "click",
      (e) => {
        if (moved) e.preventDefault();
      },
      true,
    );
  }

  document.addEventListener("astro:page-load", initFilmstripDrag);
</script>
