---
import BaseLayout from "../layouts/BaseLayout.astro";

// TODO: swap in the real repo URL once it's uploaded
const repoUrl = "#";

const shots = [
  { src: "/expense-tracker/home.png", label: "01 / dashboard at a glance", alt: "The dashboard: total spent this month, a spending chart, and a category breakdown" },
  { src: "/expense-tracker/add.png", label: "02 / log a spend in seconds", alt: "Adding an expense with a calculator-style amount pad and a category picker" },
  { src: "/expense-tracker/list.png", label: "03 / every expense, searchable", alt: "The full expense list grouped by day, with running totals" },
  { src: "/expense-tracker/plan.png", label: "04 / budgets that warn you", alt: "Per-category budgets with progress bars and a six-month pass/fail history" },
  { src: "/expense-tracker/recurring.png", label: "05 / recurring, on autopilot", alt: "Recurring rules for subscriptions and bills, with a next-30-days projection" },
  { src: "/expense-tracker/categories.png", label: "06 / categories, your way", alt: "Custom categories with an emoji and colour picker" },
  { src: "/expense-tracker/backups.png", label: "07 / nightly backups", alt: "Backup status showing the last snapshot, with JSON and CSV export" },
];

const steps = [
  {
    n: "01",
    title: "track",
    body: "a calculator-style amount pad (type 4 5 . 9 0, not tap-tap-tap through a stepper), a category picker, and it's logged. installs as a PWA and the app shell works offline; the api is online-only by design.",
  },
  {
    n: "02",
    title: "see",
    body: "monthly totals, a category breakdown, and a spending chart you can actually zoom: drill from year to month to day, with a dynamic y-axis and a horizontal scroller once bars get narrow.",
  },
  {
    n: "03",
    title: "plan",
    body: "per-category budgets with progress bars, a six-month pass/fail history at a glance, and recurring expenses that materialise themselves on schedule, month-end dates handled correctly.",
  },
  {
    n: "04",
    title: "own it",
    body: "nightly snapshots to cloud storage, JSON/CSV export any time. no subscription wall to see last month's spending, because this version doesn't have one.",
  },
];
---
<BaseLayout
  title="Gosvindraj | Expense Tracker"
  description="A self-built replacement for a paywalled budgeting app: React, Hono, and Cloudflare Workers/D1, with a dashboard, zoomable spending charts, budgets, and recurring expenses."
>
  <section id="project-expense">
    <div class="project-inner">

      <div class="project-header" data-reveal>
        <span class="m-label"><span class="lb">[</span> project <span class="hl">06</span> <span class="lb">]</span></span>
        <h1 class="project-title display">expense<br />tracker<span class="serif acid">.</span></h1>
        <p class="project-desc">
          the app I actually use to track where my money goes. built after
          the paywalled app I was using locked basic filtering behind a
          subscription: react on the front end, hono + cloudflare workers,
          d1, and r2 on the back, no framework I didn't need.
        </p>
        <p class="project-note m-note">
          this is my personal finance data, so it stays private behind auth.
          screenshots here run on generated sample data, not my real spending.
        </p>
        <a href="/projects" class="back-link m-label">&larr; all projects</a>
      </div>

      <div class="expense-wrap" data-reveal data-reveal-delay="0.15">
        <div class="filmstrip">
          {shots.map((s) => (
            <figure class="shot-card">
              <div class="shot-frame">
                <img src={s.src} alt={s.alt} loading="lazy" />
              </div>
              <figcaption class="m-label shot-cap">{s.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>

    </div>
  </section>

  <div class="expense-cta" id="expense-cta">
    <div class="project-links">
      <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="btn-solid btn-solid-invert">read the code <span aria-hidden="true">&#8599;</span></a>
    </div>
  </div>

  <section class="sec sec-ghosted" id="expense-how">
    <span class="sec-ghost display" aria-hidden="true">how</span>
    <div class="sec-head" data-reveal>
      <span class="m-label"><span class="lb">[</span> how <span class="lb">/</span> it works <span class="lb">]</span></span>
      <span class="m-label">four steps, no subscription</span>
    </div>
    <div class="steps-list">
      {steps.map((s) => (
        <div class="step-row" data-reveal>
          <span class="step-n">{s.n}</span>
          <div class="step-main">
            <span class="step-title">{s.title}</span>
            <p class="step-body">{s.body}</p>
          </div>
        </div>
      ))}
    </div>
    <a href="/projects" class="back-link back-link-bottom m-label" data-reveal>&larr; all projects</a>
  </section>

</BaseLayout>

<style>
  /* ── hero shell (mirrors the other project pages) ──────────── */
  #project-expense {
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: clamp(2.5rem, 6vh, 4rem) var(--gutter);
  }

  .project-inner {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: clamp(3rem, 7vw, 6rem);
  }

  .project-header {
    flex: 0 0 360px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .project-title { font-size: clamp(2.3rem, 5.2vw, 4rem); }

  .project-desc {
    font-size: 0.9rem;
    color: var(--dim);
    line-height: 1.85;
  }

  .project-note {
    padding-top: 0.25rem;
    border-top: 1px solid var(--line);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .back-link {
    align-self: flex-start;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--acid); }

  /* ── filmstrip ──────────────────────────────────────────────── */
  .expense-wrap {
    flex: 1;
    min-width: 0;
  }

  .filmstrip {
    display: flex;
    gap: 1.1rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    padding-bottom: 0.75rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(155, 109, 206, 0.3) transparent;
  }

  .filmstrip.dragging {
    scroll-snap-type: none;
    user-select: none;
  }

  .filmstrip::-webkit-scrollbar { height: 6px; }
  .filmstrip::-webkit-scrollbar-track { background: transparent; }
  .filmstrip::-webkit-scrollbar-thumb { background: rgba(155, 109, 206, 0.3); }
  .filmstrip::-webkit-scrollbar-thumb:hover { background: rgba(155, 109, 206, 0.55); }

  .shot-card {
    flex: 0 0 auto;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: clamp(150px, 20vw, 190px);
  }

  .shot-frame {
    aspect-ratio: 780 / 1688;
    background: var(--surface);
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shot-cap { color: var(--faint); letter-spacing: 0.14em; }

  @media (max-width: 900px) {
    .project-inner { flex-direction: column; gap: 2.5rem; }
    .project-header { flex: none; position: static; }
    .expense-wrap { width: 100%; }
  }

  .expense-cta {
    display: flex;
    justify-content: flex-start;
    padding: 0 var(--gutter) clamp(2rem, 5vw, 3rem);
  }

  /* bigger than the site's default .btn-solid — this is the page's
     one call to action, so it earns more visual weight than an
     inline nav-style button */
  .expense-cta .btn-solid {
    font-size: 13px;
    padding: 1.1rem 2.2rem;
  }

  @media (max-width: 700px) {
    .expense-cta .btn-solid {
      font-size: 11px;
      padding: 0.8rem 1.6rem;
    }
  }

  /* ── how it works ───────────────────────────────────────────── */
  .steps-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .step-row {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 2rem;
    padding: clamp(1.5rem, 3.5vw, 2.25rem) 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  .back-link-bottom {
    display: inline-block;
    margin-top: 2rem;
  }

  .step-n {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    padding-top: 0.3em;
  }

  .step-main {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .step-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
  }

  .step-body {
    max-width: 62ch;
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.8;
  }

  @media (max-width: 700px) {
    .step-row { grid-template-columns: 2.5rem 1fr; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  /* the CTA gets a scale pop-in instead of the standard data-reveal
     fade-up, since it's the page's one call to action and earns a
     bit more presence than an ordinary section reveal. no overshoot
     on the ease — back.out looked glitchy against the fixed hairline
     below it, briefly rendering larger than its settled size before
     bouncing back. */
  function initExpenseCta() {
    const cta = document.getElementById("expense-cta");
    if (!cta) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    gsap.set(cta, { opacity: 0, scale: 0.9 });
    gsap.to(cta, {
      opacity: 1,
      scale: 1,
      duration: 0.5,
      ease: "power3.out",
      scrollTrigger: { trigger: cta, start: "top 90%", once: true },
    });
  }

  document.addEventListener("astro:page-load", initExpenseCta);

  /* click-and-hold + swipe scrolling for the filmstrip. touch already
     scrolls natively, so mouse/pen pointers only. */
  function initFilmstripDrag() {
    const strip = document.querySelector<HTMLElement>(".filmstrip");
    if (!strip) return;

    let down = false;
    let dragging = false;
    let moved = false;
    let startX = 0;
    let startScroll = 0;

    strip.addEventListener("pointerdown", (e) => {
      if (e.pointerType === "touch" || e.button !== 0) return;
      down = true;
      dragging = false;
      moved = false;
      startX = e.clientX;
      startScroll = strip.scrollLeft;
    });

    strip.addEventListener("pointermove", (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      if (!dragging && Math.abs(dx) > 4) {
        dragging = true;
        moved = true;
        strip.classList.add("dragging");
        strip.setPointerCapture(e.pointerId);
      }
      if (dragging) strip.scrollLeft = startScroll - dx;
    });

    const stop = () => {
      down = false;
      dragging = false;
      strip.classList.remove("dragging");
    };
    strip.addEventListener("pointerup", stop);
    strip.addEventListener("pointercancel", stop);

    strip.addEventListener(
      "click",
      (e) => {
        if (moved) e.preventDefault();
      },
      true,
    );
  }

  document.addEventListener("astro:page-load", initFilmstripDrag);
</script>
