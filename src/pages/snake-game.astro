---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Gosvindraj | Snake Game" description="Classic 2D snake built with vanilla JS and a canvas. Arrow keys, swipe, or d-pad.">
  <section id="project-snake">
    <div class="project-inner">

      <div class="project-header">
        <span class="m-label"><span class="lb">[</span> project <span class="hl">01</span> <span class="lb">]</span></span>
        <h1 class="project-title display">snake<br />game<span class="serif acid">.</span></h1>
        <p class="project-desc">
          classic snake, built with vanilla JS and a canvas. use arrow keys
          or swipe to move, eat the food, don't hit the walls (or yourself).
        </p>
        <a href="/projects" class="back-link m-label">&larr; all projects</a>
      </div>

      <div class="game-wrap">
        <div class="game-meta m-label">
          <span>score <span class="hl" id="score-val">0</span></span>
          <span class="lb">/</span>
          <span>best <span class="hl" id="hi-val">0</span></span>
        </div>
        <canvas id="gameCanvas" width="400" height="400" tabindex="0"></canvas>
        <p class="game-hint" id="game-hint">press <kbd>enter</kbd> to start</p>
        <div class="dpad-row" id="dpad-row">
          <div class="dpad-side dpad-side-left" id="dpad-left-group">
            <button class="dpad-btn" id="dpad-up" aria-label="Up">
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
            </button>
            <button class="dpad-btn" id="dpad-down" aria-label="Down">
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          <div class="dpad-side dpad-side-right" id="dpad-right-group">
            <button class="dpad-btn" id="dpad-left" aria-label="Left">
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="dpad-btn" id="dpad-right" aria-label="Right">
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  #project-snake {
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: clamp(2.5rem, 6vh, 4rem) var(--gutter);
  }

  .project-inner {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: clamp(3rem, 7vw, 6rem);
  }

  /* left column */
  .project-header {
    flex: 0 0 320px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    opacity: 0;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .project-title {
    font-size: clamp(2.3rem, 5.2vw, 4rem);
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--dim);
    line-height: 1.85;
  }

  .back-link {
    align-self: flex-start;
    transition: color var(--transition);
  }

  .back-link:hover { color: var(--acid); }

  /* right column */
  .game-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
    opacity: 0;
  }

  .game-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  canvas {
    background: #060605;
    border: 1px solid var(--line-strong);
    outline: none;
    display: block;
    max-width: 100%;
  }

  .game-hint {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.08em;
  }

  kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.1rem 0.35rem;
    color: var(--ink);
  }

  /* d-pad */
  /* sits below the canvas, in normal flow, split into two clusters
     so both thumbs can steer at once — left thumb gets up/down,
     right thumb gets left/right. keyboard covers desktop, so this
     stays display:none until the touch/coarse-pointer query below. */
  .dpad-row {
    display: none;
    width: 100%;
    justify-content: center;
    align-items: center;
    gap: 6rem;
    margin-top: 0.25rem;
  }

  .dpad-side { display: flex; gap: 18px; }
  .dpad-side-left  { flex-direction: column; }
  .dpad-side-right { flex-direction: row; }

  .dpad-btn {
    width: 46px;
    height: 46px;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--dim);
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.1s, color 0.1s;
  }

  .dpad-btn:active {
    background: var(--acid-dim);
    color: var(--acid);
  }

  @media (hover: none), (pointer: coarse) {
    .dpad-row { display: flex; }
    .game-hint kbd { display: none; }
  }

  @media (max-width: 900px) {
    .project-inner { flex-direction: column; gap: 3rem; }
    .project-header { flex: none; position: static; }
    .game-wrap { align-items: flex-start; }
  }

  @media (max-width: 500px) {
    canvas { width: 100% !important; height: auto !important; }
    .game-wrap { align-items: center; width: 100%; }
  }
</style>

<script>
  import gsap from "gsap";

  function initSnake() {
    const canvas = document.getElementById("gameCanvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d")!;
    const hintEl   = document.getElementById("game-hint");
    const scoreEl  = document.getElementById("score-val");
    const hiEl     = document.getElementById("hi-val");
    const header   = document.querySelector<HTMLElement>(".project-header");
    const gameWrap = document.querySelector<HTMLElement>(".game-wrap");

    // entrance
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      gsap.set([header, gameWrap], { opacity: 1 });
    } else {
      gsap.fromTo(header,   { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out", delay: 0.1 });
      gsap.fromTo(gameWrap, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out", delay: 0.25 });
    }

    const isTouchDevice = () => window.matchMedia("(hover: none), (pointer: coarse)").matches;

    const BOX = 20;
    let snake: { x: number; y: number }[];
    let direction: string;
    let food: { x: number; y: number };
    let score: number;
    let highScore = parseInt(localStorage.getItem("snakeHighScore") ?? "0") || 0;
    let gameState: string;
    let game: ReturnType<typeof setInterval>;

    if (hiEl) hiEl.textContent = String(highScore);

    const foodImg = new Image();
    foodImg.src = "/favicon.svg";

    function getRandomFood() {
      let f: { x: number; y: number };
      do {
        f = { x: Math.floor(Math.random() * 20) * BOX, y: Math.floor(Math.random() * 20) * BOX };
      } while (snake.some(s => s.x === f.x && s.y === f.y));
      return f;
    }

    function init() {
      snake     = [{ x: 9 * BOX, y: 9 * BOX }];
      direction = "RIGHT";
      score     = 0;
      food      = getRandomFood();
      gameState = "start";
      if (scoreEl) scoreEl.textContent = "0";
      render();
    }

    function startGame() {
      snake     = [{ x: 9 * BOX, y: 9 * BOX }];
      direction = "RIGHT";
      score     = 0;
      food      = getRandomFood();
      gameState = "playing";
      if (hintEl) hintEl.style.visibility = "hidden";
      canvas.focus();
      if (game) clearInterval(game);
      game = setInterval(() => { update(); render(); }, 100);
    }

    function update() {
      const head = { x: snake[0].x, y: snake[0].y };
      if (direction === "LEFT")  head.x -= BOX;
      if (direction === "UP")    head.y -= BOX;
      if (direction === "RIGHT") head.x += BOX;
      if (direction === "DOWN")  head.y += BOX;

      if (head.x === food.x && head.y === food.y) {
        score++;
        if (scoreEl) scoreEl.textContent = String(score);
        if (score > highScore) {
          highScore = score;
          localStorage.setItem("snakeHighScore", String(highScore));
          if (hiEl) hiEl.textContent = String(highScore);
        }
        food = getRandomFood();
      } else {
        snake.pop();
      }

      const hitWall = head.x < 0 || head.x >= 20 * BOX || head.y < 0 || head.y >= 20 * BOX;
      const hitSelf = snake.some(s => s.x === head.x && s.y === head.y);

      if (hitWall || hitSelf) {
        clearInterval(game);
        gameState = "gameover";
        if (hintEl) { hintEl.style.visibility = "visible"; hintEl.innerHTML = isTouchDevice() ? `tap to play again` : `press <kbd>enter</kbd> to play again`; }
      } else {
        snake.unshift(head);
      }
    }

    function render() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if (gameState === "start") {
        ctx.fillStyle = "rgba(155, 109, 206,0.05)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "rgba(234,231,222,0.16)";
        ctx.font = "bold 18px 'JetBrains Mono Variable', monospace";
        ctx.textAlign = "center";
        ctx.fillText("SNAKE", canvas.width / 2, canvas.height / 2 - 10);
        ctx.fillStyle = "rgba(155, 109, 206,0.6)";
        ctx.font = "11px 'JetBrains Mono Variable', monospace";
        ctx.fillText(isTouchDevice() ? "TAP TO START" : "PRESS ENTER TO START", canvas.width / 2, canvas.height / 2 + 18);
        return;
      }

      // grid dots
      ctx.fillStyle = "rgba(234,231,222,0.04)";
      for (let x = 0; x < 20; x++) {
        for (let y = 0; y < 20; y++) {
          ctx.fillRect(x * BOX + BOX / 2 - 1, y * BOX + BOX / 2 - 1, 2, 2);
        }
      }

      // food, drawn as the favicon with a glow (skipped once the
      // game is over so it doesn't show through the semi-transparent
      // overlay behind the "game over" text)
      if (gameState !== "gameover") {
        ctx.shadowColor = "rgba(155, 109, 206,0.9)";
        ctx.shadowBlur  = 10;
        if (foodImg.complete && foodImg.naturalWidth > 0) {
          ctx.drawImage(foodImg, food.x + 1, food.y + 1, BOX - 2, BOX - 2);
        } else {
          ctx.fillStyle = "rgba(155, 109, 206,0.9)";
          ctx.fillRect(food.x + 3, food.y + 3, BOX - 6, BOX - 6);
        }
        ctx.shadowBlur = 0;
      }

      // snake
      snake.forEach((seg, idx) => {
        const alpha = idx === 0 ? 1 : Math.max(0.3, 1 - idx * 0.04);
        ctx.fillStyle = idx === 0 ? `rgba(234,231,222,${alpha})` : `rgba(155, 109, 206,${alpha})`;
        ctx.fillRect(seg.x + 1, seg.y + 1, BOX - 2, BOX - 2);
      });

      if (gameState === "gameover") {
        ctx.fillStyle = "rgba(6,6,5,0.78)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "rgba(234,231,222,0.9)";
        ctx.font      = "bold 16px 'JetBrains Mono Variable', monospace";
        ctx.textAlign = "center";
        ctx.fillText("GAME OVER", canvas.width / 2, canvas.height / 2 - 24);
        ctx.fillStyle = "rgba(155, 109, 206,0.85)";
        ctx.font      = "12px 'JetBrains Mono Variable', monospace";
        ctx.fillText(`score: ${score}  /  best: ${highScore}`, canvas.width / 2, canvas.height / 2 + 4);
      }
    }

    function changeDirection(e: KeyboardEvent) {
      if (["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(e.key)) {
        e.preventDefault();
      }
      if ((gameState === "start" || gameState === "gameover") && e.key === "Enter") {
        startGame();
      } else if (gameState === "playing") {
        if (e.key === "ArrowLeft"  && direction !== "RIGHT") direction = "LEFT";
        if (e.key === "ArrowUp"    && direction !== "DOWN")  direction = "UP";
        if (e.key === "ArrowRight" && direction !== "LEFT")  direction = "RIGHT";
        if (e.key === "ArrowDown"  && direction !== "UP")    direction = "DOWN";
      }
    }

    // touch: swipe to change direction, tap to start/restart
    let touchStartX = 0, touchStartY = 0;
    canvas.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      e.preventDefault();
    }, { passive: false });

    canvas.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (gameState === "start" || gameState === "gameover") { startGame(); return; }
      if (Math.abs(dx) < 10 && Math.abs(dy) < 10) return;
      if (Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0 && direction !== "LEFT")  direction = "RIGHT";
        else if (dx < 0 && direction !== "RIGHT") direction = "LEFT";
      } else {
        if (dy > 0 && direction !== "UP")   direction = "DOWN";
        else if (dy < 0 && direction !== "DOWN") direction = "UP";
      }
      e.preventDefault();
    }, { passive: false });

    // d-pad buttons — any button also restarts from start/gameover,
    // same as tapping the canvas
    const dpadMap: Record<string, string> = { "dpad-up": "UP", "dpad-down": "DOWN", "dpad-left": "LEFT", "dpad-right": "RIGHT" };
    Object.entries(dpadMap).forEach(([id, dir]) => {
      document.getElementById(id)?.addEventListener("touchstart", (e) => {
        e.preventDefault();
        if (gameState === "start" || gameState === "gameover") {
          startGame();
        } else if (gameState === "playing") {
          if (dir === "LEFT"  && direction !== "RIGHT") direction = "LEFT";
          if (dir === "UP"    && direction !== "DOWN")  direction = "UP";
          if (dir === "RIGHT" && direction !== "LEFT")  direction = "RIGHT";
          if (dir === "DOWN"  && direction !== "UP")    direction = "DOWN";
        }
      }, { passive: false });
    });

    // update hint and canvas prompt for touch devices
    if (isTouchDevice() && hintEl) hintEl.innerHTML = `tap canvas to start`;

    window.addEventListener("keydown", changeDirection);
    canvas.focus();
    init();

    // cleanup on page leave
    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("keydown", changeDirection);
      if (game) clearInterval(game);
    }, { once: true });
  }

  document.addEventListener("astro:page-load", initSnake);
</script>
