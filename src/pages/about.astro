---
import BaseLayout from "../layouts/BaseLayout.astro";

const timeline = [
  {
    year: "2006",
    range: "2006 - 2010",
    title: "primary school",
    place: "SK Seri Permai, Penang",
    desc: "five years in my hometown. made friends, lost erasers, somehow survived. didn't know what a computer was yet but i was already curious about everything. the pattern starts early.",
    tags: ["early life", "home"],
  },
  {
    year: "2011",
    range: "2011 - 2015",
    title: "secondary school",
    place: "Penang Free School, Penang",
    desc: "one of malaysia's oldest schools. walked in as a kid, left as someone who actually had direction. SPM came around, pulled 8As. more importantly: around 12 or 13, i discovered gaming and got obsessed with how people could connect virtually. that was the spark.",
    tags: ["secondary school", "first contact"],
  },
  {
    year: "2016",
    range: "2016 - 2017",
    title: "matriculation",
    place: "KMKT, Kelantan",
    desc: "packed my bags, moved to kelantan, and took my first real CS course. it was basic. very basic. but somewhere between the if-else blocks and the syntax errors, something clicked. i thought: yeah, i can see myself being happy doing this.",
    tags: ["matriculation", "cs begins"],
  },
  {
    year: "2017",
    range: "2017 - 2021",
    title: "degree",
    place: "Universiti Sains Malaysia, Penang",
    desc: "back home in penang. enrolled in BSc Computer Science, majoring in AI, minoring in Management. four years of figuring things out, building things, and learning what i actually care about. also directed university events with crews of 220+ people, which taught me more about humans than any textbook.",
    tags: ["university", "ai", "usm"],
  },
  {
    year: "2022",
    range: "2022 - 2025",
    title: "work",
    place: "Remote",
    desc: "spent 3 years working part-time in the web3 space: technical support and community work in the blockchain industry. got hands-on with the real side of crypto beyond the hype.",
    tags: ["web3", "blockchain", "work"],
  },
  {
    year: "2023",
    range: "2023 - 2024",
    title: "masters",
    place: "Universiti Sains Malaysia, Penang",
    desc: "went back for an MSc in Computer Science. mixed mode, dissertation in AI and Cybersecurity. another two years of going deep on things that actually matter.",
    tags: ["masters", "ai", "cybersecurity"],
  },
  {
    year: "now",
    range: "2025 - present",
    title: "building & exploring",
    place: "Penang / KL / The Internet",
    desc: "working on personal projects, doing volunteer blockchain education, and going deep on the AI and blockchain intersection. not chasing a title, just chasing the thing that's most interesting right now. if you're reading this, hi. we should probably talk.",
    tags: ["present", "ai", "blockchain", "open to collab"],
  },
];

const stack = [
  { label: "languages",   items: ["JavaScript", "TypeScript", "Python", "SQL", "HTML", "CSS"] },
  { label: "frameworks & libraries", items: ["Astro", "React", "React Native", "Expo", "GSAP", "Django"] },
  { label: "tools & infra", items: ["Git", "Node.js", "AWS", "Heroku", "Cloudflare", "Supabase", "PostgreSQL", "Telegram Bot API"] },
  { label: "ai & llms",   items: ["RAG", "xAI Grok", "Claude Code", "OpenAI Codex", "MCP"] },
  { label: "blockchain",  items: ["Solidity", "Remix IDE", "EVM", "x402", "Avalanche"] },
];

const offline = [
  { k: "beatboxing", v: "yes, actually. ask me for a demo at your own risk." },
  { k: "event direction", v: "led university events with 220+ people crews. controlled chaos is a skill." },
  { k: "public speaking", v: "give me a mic and a topic, i'll take it from there." },
  { k: "gaming", v: "where the whole 'connecting virtually' obsession started." },
];
---
<BaseLayout title="Gosvindraj | About" description="Who Gosvindraj is: AI-major computer scientist, web3 native, event director, beatboxer, and professional rabbit-hole diver from Penang.">

  <!-- ── intro ─────────────────────────────────── -->
  <section id="about-intro">
    <div class="intro-top">
      <span class="m-label"><span class="lb">[</span> about <span class="lb">/</span> the human <span class="lb">]</span></span>
      <span class="m-label">last updated: always</span>
    </div>

    <div class="intro-title-row">
      <h1 class="intro-display display">
        <span class="line-mask"><span class="line">about<span class="acid">.</span></span></span>
      </h1>
      <p class="intro-aside m-note">curious by default.</p>
    </div>

    <div class="intro-bio">
      <p>
        i'm gosvindraj, gosh for short. i build to stay sharp, not just to
        ship. some of it works. all of it teaches me something.
      </p>
    </div>
  </section>

  <!-- ── timeline ──────────────────────────────── -->
  <section class="sec sec-ghosted" id="about-journey">
    <span class="sec-ghost display" aria-hidden="true">journey</span>
    <div class="sec-head" data-reveal>
      <span class="m-label"><span class="lb">[</span> 01 <span class="lb">/</span> how i got here <span class="lb">]</span></span>
      <span class="m-label">chronological, because i respect your time</span>
    </div>

    <div class="tl-wrap">
      <!-- sticky odometer: rolls through the years as entries pass -->
      <div class="tl-sticky" aria-hidden="true">
        <span class="tl-big-mask"><span class="tl-big-year display" id="tl-big-year">{timeline[0].year}</span></span>
        <span class="m-label"><span class="hl" id="tl-step">01</span> <span class="lb">/</span> {String(timeline.length).padStart(2, "0")}</span>
      </div>

      <div class="tl-list" id="tl-list">
        <span class="tl-spine" aria-hidden="true"></span>
        {timeline.map((entry, i) => (
          <div class="tl-row" data-reveal data-year={entry.year} data-step={String(i + 1).padStart(2, "0")}>
            <div class="tl-meta m-label">
              <span class="hl">{entry.range}</span>
            </div>
            <h2 class="tl-title">{entry.title}</h2>
            <p class="tl-place">{entry.place}</p>
            <p class="tl-desc">{entry.desc}</p>
            <div class="tl-tags">
              {entry.tags.map((t) => <span class="tl-tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── stack ─────────────────────────────────── -->
  <section class="sec sec-ghosted" id="about-stack">
    <span class="sec-ghost display" aria-hidden="true">toolkit</span>
    <div class="sec-head" data-reveal>
      <span class="m-label"><span class="lb">[</span> 02 <span class="lb">/</span> the stack <span class="lb">]</span></span>
      <span class="m-label">daily drivers & experiments</span>
    </div>

    <div class="stack-grid">
      {stack.map((group, i) => (
        <div class="stack-cell" data-reveal data-reveal-delay={(i * 0.08).toFixed(2)}>
          <span class="stack-label">{group.label}</span>
          <div class="stack-tags">
            {group.items.map((item) => <span class="stack-tag">{item}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── wiring ────────────────────────────────── -->
  <section class="sec sec-ghosted" id="about-wiring">
    <span class="sec-ghost display" aria-hidden="true">wired</span>
    <div class="sec-head" data-reveal>
      <span class="m-label"><span class="lb">[</span> 03 <span class="lb">/</span> how i'm wired <span class="lb">]</span></span>
      <span class="m-label">yellow, with range</span>
    </div>

    <div class="wiring-wrap" data-reveal>
      <p class="wiring-lead">
        <span class="c-yellow">yellow</span>, according to
        <a href="https://www.surroundedbyidiots.com" target="_blank" rel="noopener noreferrer" class="wiring-ref">surrounded by idiots <span aria-hidden="true">&#8599;</span></a>.
        enthusiastic, talks too much, gets excited about everything,
        and absolutely hates sitting still.
      </p>
      <div class="wiring-body">
        <p>
          ideas come fast because i'm always scanning the frontier.
          execution follows. every project, finished or not, is how
          i stay ahead.
        </p>
        <p>
          can shift into <span class="c-blue">blue</span> when the work needs precision,
          <span class="c-red">red</span> when something needs to get done,
          <span class="c-green">green</span> when someone just needs to be heard.
          still <span class="c-yellow">yellow</span> underneath. always.
        </p>
        <p>
          naturally optimistic, probably to a fault. high energy in person,
          surprisingly focused when alone. the two modes don't always look
          like the same person.
        </p>
      </div>
    </div>
  </section>

  <!-- ── offline ───────────────────────────────── -->
  <section class="sec sec-ghosted" id="about-offline">
    <span class="sec-ghost display" aria-hidden="true">offline</span>
    <div class="sec-head" data-reveal>
      <span class="m-label"><span class="lb">[</span> 04 <span class="lb">/</span> away from the keyboard <span class="lb">]</span></span>
      <span class="m-label">allegedly i have a life</span>
    </div>

    <div class="off-list">
      {offline.map((item) => (
        <div class="off-row" data-reveal>
          <span class="off-key">{item.k}</span>
          <span class="off-val">{item.v}</span>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── intro ────────────────────────────────── */
  #about-intro {
    padding: clamp(2rem, 6vh, 3.5rem) var(--gutter) clamp(2rem, 5vh, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3.5vh, 2rem);
  }

  .intro-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  /* drop the second (note) line on narrow screens instead of
     stacking or wrapping — the bracketed tag alone is enough */
  @media (max-width: 480px) {
    .intro-top > :last-child { display: none; }
  }

  /* title + margin-note pair: the page name at a human scale with a
     serif aside beside it, instead of a full-width tagline */
  .intro-title-row {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 2.5vw, 2rem);
    flex-wrap: wrap;
  }

  .intro-display {
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  }

  /* typography comes from the shared .m-note code-comment utility */

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line { display: block; }

  .intro-bio {
    max-width: 58ch;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .intro-bio p {
    font-size: clamp(0.95rem, 1.7vw, 1.1rem);
    color: var(--dim);
    line-height: 1.85;
  }

  /* section ghosts + their scrub live in global.css / BaseLayout */

  /* ── timeline ─────────────────────────────── */
  .tl-wrap {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.6fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  /* the odometer: a giant outlined year that sticks while the
     entries scroll past, rolling to the year of whichever entry
     is crossing the middle of the viewport */
  .tl-sticky {
    position: sticky;
    top: calc(var(--nav-height) + 22vh);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tl-big-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .tl-big-year {
    display: block;
    font-size: clamp(4rem, 8.5vw, 8rem);
    color: transparent;
    -webkit-text-stroke: 1px var(--line-strong);
    will-change: transform;
  }

  .tl-list {
    position: relative;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--line);
    padding-left: clamp(1.5rem, 3.5vw, 2.5rem);
  }

  /* acid spine that draws itself down the list on scroll */
  .tl-spine {
    position: absolute;
    left: -1px;
    top: 0;
    width: 1px;
    height: 100%;
    background: var(--acid);
    transform: scaleY(0);
    transform-origin: top;
    will-change: transform;
  }

  .tl-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 62ch;
    padding: clamp(1.75rem, 4vw, 2.75rem) 0;
    border-bottom: 1px solid var(--line);
  }

  .tl-row:last-child { border-bottom: none; }

  .tl-meta {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  .tl-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 700;
    font-size: clamp(1.2rem, 2.6vw, 1.7rem);
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.1;
    transition: color 0.35s ease;
  }

  /* the entry the odometer is pointing at */
  .tl-row.active .tl-title { color: var(--acid); }

  /* location stamp: data, not commentary, so plain mono */
  .tl-place {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .tl-desc {
    font-size: 0.9rem;
    color: var(--dim);
    line-height: 1.85;
    margin-top: 0.35rem;
  }

  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .tl-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 0.25rem 0.6rem;
  }

  /* sticky odometer is a desktop + motion enhancement only */
  @media (max-width: 780px) {
    .tl-wrap { grid-template-columns: 1fr; }
    .tl-sticky { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-sticky { display: none; }
    .tl-spine { display: none; }
  }

  /* ── stack ────────────────────────────────── */
  /* real borders instead of the 1px-gap background trick, so the
     cells can stay transparent and the ghost shows through them.
     top+left on the grid, right+bottom on each cell: every edge
     ends up exactly 1px at any column count */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .stack-cell {
    background: transparent;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.25s ease;
  }

  .stack-cell:hover { background: var(--surface); }

  .stack-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--acid);
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink);
    border: 1px solid var(--line);
    padding: 0.3rem 0.65rem;
    transition: border-color var(--transition), color var(--transition), background var(--transition);
  }

  .stack-tag:hover {
    border-color: var(--acid);
    color: var(--acid);
    background: var(--acid-dim);
  }

  /* ── wiring ───────────────────────────────── */
  .wiring-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .wiring-lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    color: var(--ink);
    line-height: 1.45;
  }

  .wiring-ref {
    color: var(--acid);
    border-bottom: 1px solid rgba(155, 109, 206, 0.4);
    transition: border-color var(--transition);
  }

  .wiring-ref:hover { border-color: var(--acid); }

  .wiring-body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .wiring-body p {
    font-size: 0.92rem;
    color: var(--dim);
    line-height: 1.9;
  }

  /* personality colors: each word gets a marker-highlight sweep
     when the section scrolls into view (the .lit class, added
     staggered from JS) */
  .c-yellow, .c-blue, .c-red, .c-green {
    font-weight: 600;
    padding: 0.05em 0.14em;
    margin: 0 -0.14em;
    background-repeat: no-repeat;
    background-size: 0% 100%;
    background-position: left center;
    transition: background-size 0.55s ease;
  }

  .c-yellow.lit, .c-blue.lit,
  .c-red.lit, .c-green.lit {
    background-size: 100% 100%;
  }

  .c-yellow { color: #e8cc4a; background-image: linear-gradient(rgba(232, 204, 74, 0.16), rgba(232, 204, 74, 0.16)); }
  .c-blue   { color: #7ec8e8; background-image: linear-gradient(rgba(126, 200, 232, 0.14), rgba(126, 200, 232, 0.14)); }
  .c-red    { color: #e88888; background-image: linear-gradient(rgba(232, 136, 136, 0.14), rgba(232, 136, 136, 0.14)); }
  .c-green  { color: #80cc85; background-image: linear-gradient(rgba(128, 204, 133, 0.14), rgba(128, 204, 133, 0.14)); }

  @media (max-width: 780px) {
    .wiring-wrap { grid-template-columns: 1fr; }
  }

  /* ── offline ──────────────────────────────── */
  .off-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .off-row {
    display: grid;
    grid-template-columns: minmax(9rem, 18rem) 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0.5rem;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
    transition: background 0.25s ease, padding-left 0.25s ease;
  }

  .off-row:hover { background: var(--surface); padding-left: 1.25rem; }

  .off-key {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 700;
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
  }

  .off-val {
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .off-row { grid-template-columns: 1fr; gap: 0.4rem; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initAbout() {
    const intro = document.getElementById("about-intro");
    if (!intro || reduced) return;

    const lines = intro.querySelectorAll<HTMLElement>(".line");
    const top   = intro.querySelector<HTMLElement>(".intro-top");
    const bio   = intro.querySelectorAll<HTMLElement>(".intro-aside, .intro-bio");

    gsap.set(top, { opacity: 0 });
    gsap.set(bio, { opacity: 0, y: 20 });
    gsap.set(lines, { yPercent: 110 });

    gsap.timeline({ delay: 0.15 })
      .to(lines, { yPercent: 0, duration: 0.85, stagger: 0.12, ease: "power4.out" })
      .to(bio, { opacity: 1, y: 0, duration: 0.55, ease: "power3.out" }, "-=0.4")
      .to(top, { opacity: 1, duration: 0.5, ease: "power2.out" }, "-=0.3");
  }

  /* ghost-word scrub is handled globally in BaseLayout */

  /* ── timeline: odometer year + drawing spine ── */
  function initJourney() {
    if (reduced) return;
    const list    = document.getElementById("tl-list");
    const bigYear = document.getElementById("tl-big-year");
    const stepEl  = document.getElementById("tl-step");
    if (!list || !bigYear) return;

    const spine = list.querySelector<HTMLElement>(".tl-spine");
    if (spine) {
      gsap.fromTo(spine,
        { scaleY: 0 },
        {
          scaleY: 1,
          ease: "none",
          scrollTrigger: {
            trigger: list,
            start: "top 70%",
            end: "bottom 45%",
            scrub: 0.5,
          },
        }
      );
    }

    let current = bigYear.textContent ?? "";

    function rollTo(year: string, step: string) {
      if (!year || year === current) return;
      current = year;
      if (stepEl) stepEl.textContent = step;
      gsap.timeline()
        .to(bigYear, { yPercent: -110, duration: 0.26, ease: "power3.in" })
        .add(() => { bigYear!.textContent = year; })
        .set(bigYear, { yPercent: 110 })
        .to(bigYear, { yPercent: 0, duration: 0.34, ease: "power3.out" });
    }

    list.querySelectorAll<HTMLElement>(".tl-row").forEach((row) => {
      ScrollTrigger.create({
        trigger: row,
        start: "top 55%",
        end: "bottom 55%",
        onToggle(self) {
          row.classList.toggle("active", self.isActive);
          if (self.isActive) rollTo(row.dataset.year ?? "", row.dataset.step ?? "");
        },
      });
    });
  }

  /* ── wiring: marker sweep over the colour words ── */
  function initWiring() {
    if (reduced) return;
    const wrap = document.querySelector<HTMLElement>(".wiring-wrap");
    if (!wrap) return;

    const words = wrap.querySelectorAll<HTMLElement>(".c-yellow, .c-blue, .c-red, .c-green");
    ScrollTrigger.create({
      trigger: wrap,
      start: "top 70%",
      once: true,
      onEnter: () => {
        words.forEach((w, i) => {
          setTimeout(() => w.classList.add("lit"), 200 + i * 180);
        });
      },
    });
  }

  document.addEventListener("astro:page-load", initAbout);
  document.addEventListener("astro:page-load", initJourney);
  document.addEventListener("astro:page-load", initWiring);
</script>
