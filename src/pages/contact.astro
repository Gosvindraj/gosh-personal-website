---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Gosvindraj | Contact" description="Get in touch with Gosvindraj. Open to collabs, questions, and interesting problems.">
  <section id="contact">

    <div class="contact-head">
      <div class="ch-top">
        <span class="m-label"><span class="lb">[</span> contact <span class="lb">/</span> open channel <span class="lb">]</span></span>
        <span class="m-label">open to collabs</span>
      </div>
      <div class="ch-title-row">
        <h1 class="ch-display display">
          <span class="line-mask"><span class="line">say hi<span class="acid">.</span></span></span>
        </h1>
        <p class="ch-aside m-note">i read everything, and i actually reply.</p>
      </div>
    </div>

    <div class="contact-body">

      <div class="contact-form-col" id="contact-form-wrapper">
        <h2 class="sr-only" id="form-title">Send a message</h2>
        <form id="contact-form" autocomplete="off">
          <div class="field">
            <label for="name" class="field-label m-label">01 <span class="lb">/</span> name</label>
            <input type="text" id="name" name="name" placeholder="what do i call you?" required />
          </div>
          <div class="field">
            <label for="email" class="field-label m-label">02 <span class="lb">/</span> email</label>
            <input type="email" id="email" name="email" placeholder="where do i reply?" required />
          </div>
          <div class="field">
            <label for="message" class="field-label m-label">03 <span class="lb">/</span> message</label>
            <textarea id="message" name="message" rows="4" placeholder="what's on your mind?" required></textarea>
          </div>
          <button type="submit" class="btn-solid" data-magnetic>
            send it <span aria-hidden="true">&rarr;</span>
          </button>
        </form>
        <div id="response-message" role="status"></div>
      </div>

      <aside class="contact-aside">
        <div class="aside-block">
          <span class="m-label">direct</span>
          <a href="mailto:gosh@gosvindraj.com" class="aside-mail">gosh@gosvindraj.com</a>
        </div>

        <div class="aside-block">
          <span class="m-label">elsewhere</span>
          <ul class="aside-links">
            <li><a href="https://www.linkedin.com/in/gosvindraj-m-3306b9280/" target="_blank" rel="noopener">linkedin <span class="al-handle">gosvindraj-m <span aria-hidden="true">&#8599;</span></span></a></li>
            <li><a href="https://www.instagram.com/gosv7ndraj/" target="_blank" rel="noopener">instagram <span class="al-handle">@gosv7ndraj <span aria-hidden="true">&#8599;</span></span></a></li>
            <li><a href="https://www.facebook.com/gosvindraj.fuzz/" target="_blank" rel="noopener">facebook <span class="al-handle">gosvindraj.fuzz <span aria-hidden="true">&#8599;</span></span></a></li>
            <li><a href="https://github.com/Gosvindraj" target="_blank" rel="noopener">github <span class="al-handle">@Gosvindraj <span aria-hidden="true">&#8599;</span></span></a></li>
          </ul>
        </div>

        <div class="aside-block">
          <span class="aside-plain">penang, malaysia (gmt+8) <span class="lb">/</span> <span id="contact-clock">--:--:--</span></span>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>

<style>
  #contact {
    padding: clamp(1.5rem, 4vh, 2.5rem) var(--gutter) clamp(1.25rem, 3vh, 2rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 5vh, 3rem);
  }

  /* on desktop, cap the whole page to one viewport instead of
     letting it grow past it — mirrors the home page treatment.
     mobile sizes to its actual content instead of forcing a full
     viewport minimum, which used to leave dead space above the
     footer once the footer bar was re-enabled on this page */
  @media (min-width: 821px) {
    #contact {
      height: calc(100vh - var(--nav-height));
      overflow: hidden;
    }

    .contact-head { flex-shrink: 0; }

    .contact-body {
      flex: 1;
      min-height: 0;
    }
  }

  .contact-head {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 3vh, 1.75rem);
  }

  .ch-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  /* drop the second (note) line on narrow screens instead of
     stacking or wrapping — the bracketed tag alone is enough */
  @media (max-width: 480px) {
    .ch-top > :last-child { display: none; }
  }

  /* title + margin-note pair: the page name at a human scale with a
     serif aside beside it, instead of a full-width tagline */
  .ch-title-row {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 2.5vw, 2rem);
    flex-wrap: wrap;
  }

  .ch-display { font-size: clamp(2.4rem, min(5.5vw, 8vh), 4.2rem); }

  /* typography comes from the shared .m-note code-comment utility */

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line { display: block; }

  .contact-body {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    border-top: 1px solid var(--line);
    padding-top: clamp(1.25rem, 3vh, 2rem);
  }

  /* ── form ─────────────────────────────────── */
  #contact-form {
    display: flex;
    flex-direction: column;
    gap: clamp(1.1rem, 3vh, 1.75rem);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    border-bottom: 1px solid var(--line);
    transition: border-color var(--transition);
    padding-bottom: 0.25rem;
  }

  .field:focus-within { border-color: var(--acid); }

  .field-label { color: var(--faint); }

  .field:focus-within .field-label { color: var(--acid); }

  .field input,
  .field textarea {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.35rem 0 0.85rem;
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    resize: none;
    cursor: none;
  }

  .field input:-webkit-autofill,
  .field input:-webkit-autofill:hover,
  .field input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px var(--bg) inset;
    -webkit-text-fill-color: var(--ink);
    caret-color: var(--ink);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--faint);
    font-weight: 400;
  }

  /* full-width ledger-row send bar instead of a small button
     floating in the empty bottom-left corner */
  #contact-form button[type="submit"] {
    width: 100%;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    will-change: transform;
  }

  /* response */
  #response-message {
    display: none;
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    line-height: 1.6;
  }

  #response-message.response-success {
    display: block;
    border: 1px solid rgba(155, 109, 206, 0.4);
    background: var(--acid-dim);
    color: var(--acid);
  }

  #response-message.response-error {
    display: block;
    border: 1px solid rgba(var(--bad-rgb), 0.35);
    background: rgba(var(--bad-rgb), 0.08);
    color: var(--bad);
    animation: fadeOut 4s forwards;
  }

  .fade-out { opacity: 0; transition: opacity 0.4s ease; }
  .fade-in  { opacity: 0; display: block; animation: fadeIn 0.4s ease forwards; }

  @keyframes fadeIn  { to { opacity: 1; } }
  @keyframes fadeOut {
    0%, 75% { opacity: 1; }
    100%    { opacity: 0; }
  }

  /* ── aside ────────────────────────────────── */
  /* height is pinned to the form column's actual rendered height
     via JS (see initAsideHeight) — stretching it with CSS alone
     matched .contact-body's full leftover viewport space instead
     of the form's real height, overshooting past the button */
  .contact-aside {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: clamp(1.5rem, 4vh, 2.5rem);
  }

  @media (min-width: 781px) {
    .contact-aside {
      border-left: 1px solid var(--line);
      padding-left: clamp(2rem, 4vw, 3.5rem);
    }
  }

  /* typography comes from the shared .m-note code-comment utility */

  .aside-block {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .aside-block .m-label { line-height: 1; }

  .aside-mail {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 700;
    font-size: clamp(1.1rem, 2.4vw, 1.5rem);
    letter-spacing: -0.02em;
    color: var(--ink);
    transition: color var(--transition);
    word-break: break-all;
  }

  .aside-mail:hover { color: var(--acid); }

  .aside-links {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  /* content, not a second label: sans-serif, lowercase, ink-toned,
     bigger — same contrast the "direct" block gets from its big
     bold email against the small mono label above it */
  .aside-links a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.65rem 0.4rem;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    text-transform: lowercase;
    color: var(--ink);
    transition: background var(--transition), color var(--transition), padding-left var(--transition);
  }

  .al-handle {
    color: var(--faint);
    letter-spacing: 0.08em;
    text-transform: none;
    transition: color var(--transition);
  }

  /* the site's row-invert move, at ledger-row scale */
  .aside-links a:hover {
    background: var(--acid);
    color: var(--bg);
    padding-left: 0.9rem;
  }

  .aside-links a:hover .al-handle { color: var(--bg); }

  .aside-plain {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .aside-plain .lb { color: var(--faint); }

  #contact-clock { color: var(--acid); font-variant-numeric: tabular-nums; }

  @media (max-width: 780px) {
    .contact-body { grid-template-columns: 1fr; }
    #contact-form button[type="submit"] { align-self: stretch; justify-content: center; }
  }
</style>

<script>
  import gsap from "gsap";
  import { API_BASE } from "../lib/api";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initContact() {
    const head  = document.querySelector<HTMLElement>(".contact-head");
    const body  = document.querySelector<HTMLElement>(".contact-body");
    if (!head) return;

    if (!reduced) {
      const lines = head.querySelectorAll<HTMLElement>(".line");
      const top   = head.querySelector<HTMLElement>(".ch-top");
      const aside = head.querySelector<HTMLElement>(".ch-aside");

      gsap.set(top, { opacity: 0 });
      gsap.set(aside, { opacity: 0, y: 12 });
      gsap.set(body, { opacity: 0, y: 24 });
      gsap.set(lines, { yPercent: 110 });

      gsap.timeline({ delay: 0.15 })
        .to(lines, { yPercent: 0, duration: 0.85, stagger: 0.12, ease: "power4.out" })
        .to(aside, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" }, "-=0.5")
        .to(body, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" }, "-=0.35")
        .to(top, { opacity: 1, duration: 0.5, ease: "power2.out" }, "-=0.3");
    }

    /* magnetic submit button */
    const submitBtn = document.querySelector<HTMLElement>("[data-magnetic]");
    if (submitBtn && !reduced) {
      submitBtn.addEventListener("mousemove", (e) => {
        const rect = submitBtn.getBoundingClientRect();
        gsap.to(submitBtn, {
          x: (e.clientX - (rect.left + rect.width / 2)) * 0.35,
          y: (e.clientY - (rect.top + rect.height / 2)) * 0.35,
          duration: 0.3,
          ease: "power2.out",
        });
      });
      submitBtn.addEventListener("mouseleave", () => {
        gsap.to(submitBtn, { x: 0, y: 0, duration: 0.5, ease: "elastic.out(1, 0.5)" });
      });
    }
  }

  /* ── form submit ─────────────────────────── */
  function initForm() {
    document.getElementById("contact-form")?.addEventListener("submit", async function (event) {
      event.preventDefault();

      const form    = document.getElementById("contact-form")         as HTMLFormElement;
      const msg     = document.getElementById("response-message")     as HTMLElement;

      const name    = (form.querySelector<HTMLInputElement>("#name"))?.value ?? "";
      const email   = (form.querySelector<HTMLInputElement>("#email"))?.value ?? "";
      const message = (form.querySelector<HTMLTextAreaElement>("#message"))?.value ?? "";

      try {
        const res = await fetch(`${API_BASE}/api/contact`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, email, message }),
        });

        if (res.ok) {
          form.classList.add("fade-out");
          setTimeout(() => {
            form.style.display = "none";
            msg.className = "response-success fade-in";
            msg.textContent = "message sent. i'll get back to you soon.";
          }, 400);
        } else {
          msg.className = "response-error";
          msg.textContent = "something went wrong. please try again.";
          setTimeout(() => { msg.className = ""; msg.textContent = ""; }, 4000);
        }
      } catch {
        msg.className = "response-error";
        msg.textContent = "something went wrong. please try again.";
        setTimeout(() => { msg.className = ""; msg.textContent = ""; }, 4000);
      }
    });
  }

  /* ── live MYT clock in the location line ──── */
  function initClock() {
    const el = document.getElementById("contact-clock");
    if (!el) return;
    const fmt = new Intl.DateTimeFormat("en-GB", {
      timeZone: "Asia/Kuala_Lumpur",
      hour: "2-digit", minute: "2-digit", second: "2-digit",
      hour12: false,
    });
    const tick = () => { el.textContent = fmt.format(new Date()); };
    tick();
    const timer = setInterval(tick, 1000);
    document.addEventListener("astro:before-swap", () => clearInterval(timer), { once: true });
  }

  /* ── pin the aside's height to the form's rendered height ──
     so the location line (via justify-content: space-between)
     lands flush with the bottom of the form, not the taller
     leftover space .contact-body gets stretched to on desktop */
  function initAsideHeight() {
    const form  = document.getElementById("contact-form-wrapper");
    const aside = document.querySelector<HTMLElement>(".contact-aside");
    if (!form || !aside) return;

    function sync() {
      if (window.matchMedia("(min-width: 781px)").matches) {
        aside!.style.minHeight = form!.offsetHeight + "px";
      } else {
        aside!.style.minHeight = "";
      }
    }

    sync();
    window.addEventListener("resize", sync);
    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("resize", sync);
    }, { once: true });
  }

  document.addEventListener("astro:page-load", initContact);
  document.addEventListener("astro:page-load", initForm);
  document.addEventListener("astro:page-load", initClock);
  document.addEventListener("astro:page-load", initAsideHeight);
</script>
