---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Gosvindraj | 404" hideFooter={true}>
  <section id="not-found">
    <span class="m-label"><span class="lb">[</span> error <span class="hl">404</span> <span class="lb">]</span></span>
    <h1 class="err-display display">
      <span class="line-mask"><span class="line">lost</span></span><span class="serif acid err-mark">?</span>
    </h1>
    <p class="err-sub">this page doesn't exist. or it did, and we moved on.</p>
    <a href="/" class="btn-solid">back to home <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
  </section>
</BaseLayout>

<style>
  #not-found {
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem var(--gutter);
    gap: 1.75rem;
  }

  .err-display { font-size: clamp(4.2rem, 18vw, 13rem); }

  .line-mask {
    display: inline-block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line { display: block; }

  /* kept outside .line-mask entirely: the serif italic glyph's
     ascender overshoots the tight Archivo line box the mask clips
     to, at every size tested, so it can never live inside a
     clipped reveal without getting its curl cut off. it just fades
     in with the rest of the page content instead. */
  .err-mark {
    display: inline;
  }

  .err-sub {
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    color: var(--dim);
    line-height: 1.7;
    max-width: 40ch;
  }
</style>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function init404() {
    const sec = document.getElementById("not-found");
    if (!sec || reduced) return;

    const line = sec.querySelectorAll<HTMLElement>(".line");
    const mark = sec.querySelectorAll<HTMLElement>(".err-mark");
    const rest = sec.querySelectorAll<HTMLElement>(".m-label, .err-sub, .btn-solid");

    gsap.set(line, { yPercent: 110 });
    gsap.set(mark, { opacity: 0 });
    gsap.set(rest, { opacity: 0, y: 14 });

    gsap.timeline({ delay: 0.1 })
      .to(line, { yPercent: 0, duration: 0.85, ease: "power4.out" })
      .to(mark, { opacity: 1, duration: 0.4, ease: "power2.out" }, "-=0.35")
      .to(rest, { opacity: 1, y: 0, duration: 0.5, stagger: 0.08, ease: "power3.out" }, "-=0.3");
  }

  document.addEventListener("astro:page-load", init404);
</script>
