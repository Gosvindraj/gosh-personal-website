---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    index: "01",
    title: "snake game",
    summary: "classic 2D snake on a canvas. arrow keys, swipe, or d-pad. the food is my favicon, because branding.",
    tags: ["canvas", "vanilla js"],
    href: "/snake-game",
    cta: "play it",
  },
  {
    index: "02",
    title: "btc / myr tracker",
    summary: "live bitcoin price in ringgit. pulls BTC/USD and the USD/MYR rate, converts on the spot, draws a 7-day sparkline.",
    tags: ["api", "fintech"],
    href: "/crypto-api",
    cta: "check the price",
  },
  {
    index: "03",
    title: "anomaly detector",
    summary: "paste an avalanche c-chain wallet and an isolation forest model scores every transaction for value, gas, and timing outliers.",
    tags: ["ml", "avalanche", "security"],
    href: "/anomaly-detector",
    cta: "scan a wallet",
  },
  {
    index: "04",
    title: "ai news bot",
    summary: "a grok-powered agent that reads the internet daily, curates the top AI stories, and auto-posts them to instagram on a cron.",
    tags: ["agents", "cloudflare workers", "grok"],
    href: "#instagram-feed",
    cta: "see the feed",
  },
  {
    index: "05",
    title: "this website",
    summary: "the thing you're looking at. astro, gsap, react islands, and an unreasonable number of hairlines. perpetually under construction.",
    tags: ["astro", "gsap", "meta"],
    href: "/about",
    cta: "meet the builder",
  },
];
---
<BaseLayout title="Gosvindraj | Projects" description="Things Gosvindraj built: browser games, crypto tools, ML anomaly detection, and AI agents." hideFootCta={true}>

  <section id="projects-head">
    <div class="ph-top">
      <span class="m-label"><span class="lb">[</span> work <span class="lb">/</span> index <span class="lb">]</span></span>
      <span class="m-label">{projects.length} entries, more compiling</span>
    </div>
    <h1 class="ph-display display">
      <span class="line-mask"><span class="line">built to</span></span>
      <span class="line-mask"><span class="line"><span class="serif acid">learn.</span></span></span>
    </h1>
    <p class="ph-sub">
      nothing here was made to pad a resume. each one exists because
      i wanted to know how something worked.
    </p>
  </section>

  <section class="sec" id="projects-list">
    <div class="proj-list">
      {projects.map((p) => (
        <a href={p.href} class="proj-row" data-reveal>
          <span class="proj-index">{p.index}</span>
          <div class="proj-main">
            <span class="proj-title">{p.title}</span>
            <p class="proj-summary">{p.summary}</p>
            <div class="proj-tags">
              {p.tags.map((t) => <span class="proj-tag">{t}</span>)}
            </div>
          </div>
          <span class="proj-cta m-label">{p.cta} <span aria-hidden="true">&#8599;</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── instagram feed ────────────────────────── -->
  <section class="sec" id="instagram-feed">
    <div class="sec-head" data-reveal>
      <span class="m-label" id="insta-label"><span class="lb">[</span> live <span class="lb">/</span> ai daily roundup <span class="lb">]</span></span>
      <a href="https://www.instagram.com/agentgosh/" target="_blank" rel="noopener noreferrer" class="m-label insta-follow">@agentgosh <span class="hl">follow &#8599;</span></a>
    </div>
    <p class="insta-desc" data-reveal>
      posted daily by the news bot above. zero human hands involved.
    </p>
    <div class="insta-grid" id="insta-grid" data-reveal></div>
  </section>

</BaseLayout>

<style>
  /* ── header ───────────────────────────────── */
  #projects-head {
    padding: clamp(2rem, 6vh, 4rem) var(--gutter) clamp(3rem, 8vh, 5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 5vh, 3rem);
  }

  .ph-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .ph-display { font-size: clamp(2.8rem, 10vw, 8.5rem); }

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line { display: block; }

  .ph-sub {
    max-width: 48ch;
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    color: var(--dim);
    line-height: 1.85;
  }

  /* ── list ─────────────────────────────────── */
  #projects-list { padding-top: 0; border-top: none; }

  .proj-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .proj-row {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    gap: 2rem;
    align-items: start;
    padding: clamp(1.75rem, 4.5vw, 3rem) 0.5rem;
    border-bottom: 1px solid var(--line);
    transition: background 0.25s ease, padding-left 0.25s ease;
  }

  .proj-index {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    padding-top: 0.6em;
    transition: color 0.25s ease;
  }

  .proj-main {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-width: 0;
  }

  .proj-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: clamp(1.8rem, 5.5vw, 3.6rem);
    letter-spacing: -0.03em;
    line-height: 0.98;
    text-transform: lowercase;
    color: var(--ink);
    transition: color 0.25s ease;
  }

  .proj-summary {
    max-width: 56ch;
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.75;
    transition: color 0.25s ease;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.35rem;
  }

  .proj-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 0.25rem 0.6rem;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .proj-cta {
    padding-top: 0.8em;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .proj-row:hover { background: var(--acid); padding-left: 1.25rem; }
  .proj-row:hover .proj-title,
  .proj-row:hover .proj-summary,
  .proj-row:hover .proj-index,
  .proj-row:hover .proj-cta { color: #0c0c0a; }
  .proj-row:hover .proj-cta .hl { color: #0c0c0a; }
  .proj-row:hover .proj-tag { color: #0c0c0a; border-color: rgba(12, 12, 10, 0.4); }

  @media (max-width: 700px) {
    .proj-row { grid-template-columns: 2.5rem 1fr; }
    .proj-cta { display: none; }
  }

  /* ── instagram ────────────────────────────── */
  .insta-follow { transition: color var(--transition); }
  .insta-follow:hover { color: var(--ink); }

  .insta-desc {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--dim);
    margin-bottom: 2rem;
  }

  .insta-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  @media (max-width: 1100px) {
    .insta-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 700px) {
    .insta-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<style is:global>
  /* instagram cards are injected via JS, so styles must be global */
  .insta-card {
    position: relative;
    overflow: hidden;
    display: block;
    background: var(--bg);
  }

  .insta-thumb {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  .insta-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(35%);
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .insta-card:hover .insta-thumb img {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .insta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(12, 12, 10, 0.25);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    transition: background 0.25s ease;
    z-index: 1;
  }

  .insta-card:hover .insta-overlay { background: rgba(12, 12, 10, 0.78); }

  .insta-view,
  .insta-type-badge {
    opacity: 0;
    transition: opacity 0.25s ease;
    font-family: "JetBrains Mono", monospace;
  }

  .insta-card:hover .insta-view,
  .insta-card:hover .insta-type-badge { opacity: 1; }

  .insta-view {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .insta-type-badge {
    font-size: 10px;
    color: var(--acid);
    letter-spacing: 0.08em;
  }

  .insta-status {
    grid-column: 1 / -1;
    padding: 3rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--dim);
    font-family: "JetBrains Mono", monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initHeader() {
    const head = document.getElementById("projects-head");
    if (!head || reduced) return;

    const lines = head.querySelectorAll<HTMLElement>(".line");
    const top   = head.querySelector<HTMLElement>(".ph-top");
    const sub   = head.querySelector<HTMLElement>(".ph-sub");

    gsap.set(top, { opacity: 0 });
    gsap.set(sub, { opacity: 0, y: 20 });
    gsap.set(lines, { yPercent: 110 });

    gsap.timeline({ delay: 0.15 })
      .to(lines, { yPercent: 0, duration: 0.85, stagger: 0.12, ease: "power4.out" })
      .to(sub, { opacity: 1, y: 0, duration: 0.55, ease: "power3.out" }, "-=0.4")
      .to(top, { opacity: 1, duration: 0.5, ease: "power2.out" }, "-=0.3");
  }

  interface InstaPost {
    id: string;
    caption: string;
    media_type: "IMAGE" | "VIDEO" | "CAROUSEL_ALBUM";
    media_url: string;
    thumbnail_url?: string;
    permalink: string;
    timestamp: string;
  }

  async function initInstagramFeed() {
    const grid = document.getElementById("insta-grid");
    if (!grid) return;

    grid.innerHTML = `<p class="insta-status">loading feed...</p>`;

    try {
      const res = await fetch("https://marketing-automation-api.gosvind.workers.dev/api/public/instagram-feed");
      if (!res.ok) throw new Error("api error");
      const data = await res.json() as { posts: InstaPost[] };
      const posts = (data.posts ?? []).slice(0, 12);

      if (!posts.length) {
        grid.innerHTML = `<p class="insta-status">no posts yet.</p>`;
        return;
      }

      grid.innerHTML = posts.map((post) => {
        const src   = post.media_type === "VIDEO" ? (post.thumbnail_url ?? "") : post.media_url;
        const badge = post.media_type === "VIDEO"
          ? `<span class="insta-type-badge">&#9654; video</span>`
          : "";
        return `<a href="${post.permalink}" target="_blank" rel="noopener noreferrer" class="insta-card" aria-label="View post on Instagram">
          <div class="insta-thumb">
            <img src="${src}" alt="" loading="lazy">
            <div class="insta-overlay">${badge}<span class="insta-view">view on ig &#8599;</span></div>
          </div>
        </a>`;
      }).join("");

      if (!reduced) {
        gsap.fromTo(grid.querySelectorAll(".insta-card"),
          { opacity: 0, y: 24 },
          {
            opacity: 1, y: 0,
            stagger: { amount: 0.5, from: "start" },
            duration: 0.5,
            ease: "power3.out",
            scrollTrigger: { trigger: grid, start: "top 85%", once: true },
          }
        );
      }
    } catch {
      grid.innerHTML = `<p class="insta-status">couldn't load feed.</p>`;
    }
  }

  document.addEventListener("astro:page-load", initHeader);
  document.addEventListener("astro:page-load", initInstagramFeed);
</script>
