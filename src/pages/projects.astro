---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    index: "01",
    title: "snake game",
    summary: "classic 2D snake on a canvas. arrow keys, swipe, or d-pad. the food is my favicon, because branding.",
    tags: ["canvas", "vanilla js"],
    href: "/snake-game",
    cta: "play it",
  },
  {
    index: "02",
    title: "btc / myr tracker",
    summary: "live bitcoin price in ringgit. pulls BTC/USD and the USD/MYR rate, converts on the spot, draws a 7-day sparkline.",
    tags: ["api", "fintech"],
    href: "/crypto-api",
    cta: "check the price",
  },
  {
    index: "03",
    title: "anomaly detector",
    summary: "paste an avalanche c-chain wallet and an isolation forest model scores every transaction for value, gas, and timing outliers.",
    tags: ["ml", "avalanche", "security"],
    href: "/anomaly-detector",
    cta: "scan a wallet",
  },
  {
    index: "04",
    title: "ai news bot",
    summary: "a grok-powered agent that reads the internet daily, curates the top AI stories, and auto-posts them to instagram on a cron.",
    tags: ["agents", "cloudflare workers", "grok"],
    href: "#instagram-feed",
    cta: "see the feed",
  },
  {
    index: "05",
    title: "this website",
    summary: "the thing you're looking at. astro, gsap, react islands, and an unreasonable number of hairlines. perpetually under construction.",
    tags: ["astro", "gsap", "meta"],
    href: "/about",
    cta: "meet the builder",
  },
];
---
<BaseLayout title="Gosvindraj | Projects" description="Things Gosvindraj built: browser games, crypto tools, ML anomaly detection, and AI agents.">

  <section id="projects-head">
    <div class="ph-top">
      <span class="m-label"><span class="lb">[</span> work <span class="lb">/</span> index <span class="lb">]</span></span>
      <span class="m-label">{projects.length} entries, more compiling</span>
    </div>
    <div class="ph-title-row">
      <h1 class="ph-display display">
        <span class="line-mask"><span class="line">projects<span class="acid">.</span></span></span>
      </h1>
      <p class="ph-aside m-note">built to learn, not to impress.</p>
    </div>
    <p class="ph-sub">
      each one exists because i wanted to know how something worked.
      nothing here was made to pad a resume.
    </p>
  </section>

  <section class="sec sec-ghosted" id="projects-list">
    <span class="sec-ghost display" aria-hidden="true">built</span>
    <div class="proj-list">
      {projects.map((p) => (
        <a href={p.href} class="proj-row" data-reveal>
          <span class="proj-index">{p.index}</span>
          <div class="proj-main">
            <span class="proj-title">{p.title}</span>
            <p class="proj-summary">{p.summary}</p>
            <div class="proj-tags">
              {p.tags.map((t) => <span class="proj-tag">{t}</span>)}
            </div>
          </div>
          <span class="proj-cta m-label">{p.cta} <span aria-hidden="true">&#8599;</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── instagram feed ────────────────────────── -->
  <section class="sec sec-ghosted" id="instagram-feed">
    <span class="sec-ghost display" aria-hidden="true">daily</span>
    <div class="sec-head" data-reveal>
      <span class="m-label" id="insta-label"><span class="lb">[</span> live <span class="lb">/</span> ai daily roundup <span class="lb">]</span></span>
      <a href="https://www.instagram.com/agentgosh/" target="_blank" rel="noopener noreferrer" class="m-label insta-follow">@agentgosh <span class="hl">follow &#8599;</span></a>
    </div>
    <p class="insta-desc m-note" data-reveal>
      posted daily by the news bot above. zero human hands involved.
    </p>
    <div id="insta-wrap"></div>
  </section>

</BaseLayout>

<style>
  /* ── header ───────────────────────────────── */
  #projects-head {
    padding: clamp(2rem, 6vh, 3.5rem) var(--gutter) clamp(2rem, 5vh, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3.5vh, 2rem);
  }

  .ph-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  /* drop the second (note) line on narrow screens instead of
     stacking or wrapping — the bracketed tag alone is enough */
  @media (max-width: 480px) {
    .ph-top > :last-child { display: none; }
  }

  /* title + margin-note pair: the page name at a human scale with a
     serif aside beside it, instead of a full-width tagline */
  .ph-title-row {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 2.5vw, 2rem);
    flex-wrap: wrap;
  }

  .ph-display { font-size: clamp(2.4rem, 5.5vw, 4.2rem); }

  /* typography comes from the shared .m-note code-comment utility */

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line { display: block; }

  .ph-sub {
    max-width: 48ch;
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    color: var(--dim);
    line-height: 1.85;
  }

  /* ── list ─────────────────────────────────── */
  #projects-list { padding-top: 0; border-top: none; }

  .proj-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line);
  }

  .proj-row {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    gap: 2rem;
    align-items: start;
    padding: clamp(1.75rem, 4.5vw, 3rem) 0.5rem;
    border-bottom: 1px solid var(--line);
    transition: background 0.25s ease, padding-left 0.25s ease;
  }

  .proj-index {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
    padding-top: 0.6em;
    transition: color 0.25s ease;
  }

  .proj-main {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-width: 0;
  }

  .proj-title {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: clamp(1.8rem, 5.5vw, 3.6rem);
    letter-spacing: -0.03em;
    line-height: 0.98;
    text-transform: lowercase;
    color: var(--ink);
    transition: color 0.25s ease;
  }

  .proj-summary {
    max-width: 56ch;
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.75;
    transition: color 0.25s ease;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.35rem;
  }

  .proj-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    border: 1px solid var(--line);
    padding: 0.25rem 0.6rem;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .proj-cta {
    padding-top: 0.8em;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .proj-row:hover { background: var(--acid); padding-left: 1.25rem; }
  .proj-row:hover .proj-title,
  .proj-row:hover .proj-summary,
  .proj-row:hover .proj-index,
  .proj-row:hover .proj-cta { color: var(--bg); }
  .proj-row:hover .proj-cta .hl { color: var(--bg); }
  .proj-row:hover .proj-tag { color: var(--bg); border-color: rgba(12, 12, 10, 0.4); }

  @media (max-width: 700px) {
    .proj-row { grid-template-columns: 2.5rem 1fr; }
    .proj-cta { display: none; }
  }

  /* ── instagram ────────────────────────────── */
  .insta-follow { transition: color var(--transition); }
  .insta-follow:hover { color: var(--ink); }

  .insta-desc { margin-bottom: 2rem; }
</style>

<style is:global>
  /* the feed is injected via JS, so its styles must be global.
     layout: the latest post gets a feature treatment (image + meta
     column with the date as the hero, since the date is the only
     thing that changes between these daily posters), the rest sit
     below as a compact dated archive. */

  /* ── feature: latest drop ── */
  .insta-feature {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    border: 1px solid var(--line);
  }

  .if-img {
    position: relative;
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--surface);
  }

  /* the posters are dark art already: show them at full colour and
     let the hover overlay do the dimming, not the resting state */
  .if-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .if-img:hover img {
    transform: scale(1.04);
  }

  .insta-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    transition: background 0.25s ease;
    z-index: 1;
  }

  .if-img:hover .insta-overlay { background: rgba(12, 12, 10, 0.78); }

  .insta-view,
  .insta-type-badge {
    opacity: 0;
    transition: opacity 0.25s ease;
    font-family: var(--font-mono);
  }

  .if-img:hover .insta-view,
  .if-img:hover .insta-type-badge { opacity: 1; }

  .insta-view {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .insta-type-badge {
    font-size: 10px;
    color: var(--acid);
    letter-spacing: 0.08em;
  }

  .if-meta {
    border-left: 1px solid var(--line);
    padding: clamp(1.5rem, 3.5vw, 3rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.1rem;
    min-width: 0;
  }

  .if-date {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: clamp(1.9rem, 4.5vw, 3.4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    text-transform: lowercase;
    color: var(--ink);
  }

  .if-date .tick { color: var(--acid); }

  .if-caption {
    max-width: 52ch;
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.8;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .if-meta .btn-line { align-self: flex-start; }

  /* ── archive: the rest, as a dated contact sheet ── */
  .insta-archive {
    border: 1px solid var(--line);
    border-top: none;
  }

  .ia-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .ia-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: var(--line);
  }

  .ia-tile {
    display: block;
    background: var(--bg);
    min-width: 0;
  }

  .ia-thumb {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
  }

  /* light desaturation only, so the feature still reads as "the one
     in colour" but the archive no longer sinks into the background */
  .ia-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(30%);
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .ia-tile:hover .ia-thumb img {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  /* the tag bar carries the tile's actual information (index + date)
     and inverts to acid on hover, echoing the site's row-invert move */
  .ia-tag {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0.65rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
    transition: background 0.25s ease, color 0.25s ease;
  }

  .ia-tag .ia-date { color: var(--dim); transition: color 0.25s ease; }

  .ia-tile:hover .ia-tag,
  .ia-tile:hover .ia-tag .ia-date {
    background: var(--acid);
    color: var(--bg);
  }

  .insta-status {
    padding: 3rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--dim);
    font-family: var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--line);
  }

  @media (max-width: 1100px) {
    .ia-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 780px) {
    .insta-feature { grid-template-columns: 1fr; }
    .if-meta { border-left: none; border-top: 1px solid var(--line); }
    .ia-grid { grid-template-columns: repeat(3, 1fr); }
    .ia-head .m-label:last-child { display: none; }
  }

  @media (max-width: 480px) {
    .ia-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function initHeader() {
    const head = document.getElementById("projects-head");
    if (!head || reduced) return;

    const lines = head.querySelectorAll<HTMLElement>(".line");
    const top   = head.querySelector<HTMLElement>(".ph-top");
    const sub   = head.querySelectorAll<HTMLElement>(".ph-aside, .ph-sub");

    gsap.set(top, { opacity: 0 });
    gsap.set(sub, { opacity: 0, y: 20 });
    gsap.set(lines, { yPercent: 110 });

    gsap.timeline({ delay: 0.15 })
      .to(lines, { yPercent: 0, duration: 0.85, stagger: 0.12, ease: "power4.out" })
      .to(sub, { opacity: 1, y: 0, duration: 0.55, ease: "power3.out" }, "-=0.4")
      .to(top, { opacity: 1, duration: 0.5, ease: "power2.out" }, "-=0.3");
  }

  interface InstaPost {
    id: string;
    caption: string;
    media_type: "IMAGE" | "VIDEO" | "CAROUSEL_ALBUM";
    media_url: string;
    thumbnail_url?: string;
    permalink: string;
    timestamp: string;
  }

  function esc(s: string) {
    return s.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c] ?? c));
  }

  function cleanCaption(c: string) {
    const text = (c ?? "").replace(/#\w+/g, "").replace(/\s+/g, " ").trim();
    return text.length > 200 ? text.slice(0, 200).trimEnd() + "..." : text;
  }

  function fmtLong(ts: string) {
    return new Date(ts)
      .toLocaleDateString("en-GB", { day: "2-digit", month: "long", year: "numeric" })
      .toLowerCase();
  }

  function fmtShort(ts: string) {
    return new Date(ts)
      .toLocaleDateString("en-GB", { day: "2-digit", month: "short" })
      .toLowerCase();
  }

  function srcOf(p: InstaPost) {
    return p.media_type === "VIDEO" ? (p.thumbnail_url ?? "") : p.media_url;
  }

  async function initInstagramFeed() {
    const wrap = document.getElementById("insta-wrap");
    if (!wrap) return;

    wrap.innerHTML = `<p class="insta-status">loading feed...</p>`;

    try {
      const res = await fetch("https://marketing-automation-api.gosvind.workers.dev/api/public/instagram-feed");
      if (!res.ok) throw new Error("api error");
      const data = await res.json() as { posts: InstaPost[] };
      const posts = (data.posts ?? []).slice(0, 11);

      if (!posts.length) {
        wrap.innerHTML = `<p class="insta-status">no posts yet.</p>`;
        return;
      }

      const [latest, ...rest] = posts;
      const caption = cleanCaption(latest.caption);
      const badge = latest.media_type === "VIDEO"
        ? `<span class="insta-type-badge">&#9654; video</span>`
        : "";

      const feature = `
        <div class="insta-feature">
          <a href="${latest.permalink}" target="_blank" rel="noopener noreferrer" class="if-img" aria-label="View latest post on Instagram">
            <img src="${srcOf(latest)}" alt="">
            <div class="insta-overlay">${badge}<span class="insta-view">view on ig &#8599;</span></div>
          </a>
          <div class="if-meta">
            <span class="m-label"><span class="lb">[</span> 01 <span class="lb">/</span> latest drop <span class="lb">]</span></span>
            <span class="if-date">${fmtLong(latest.timestamp)}<span class="tick">.</span></span>
            ${caption ? `<p class="if-caption">${esc(caption)}</p>` : ""}
            <a href="${latest.permalink}" target="_blank" rel="noopener noreferrer" class="btn-line">view the drop <span aria-hidden="true">&#8599;</span></a>
          </div>
        </div>`;

      const archive = rest.length ? `
        <div class="insta-archive">
          <div class="ia-head">
            <span class="m-label"><span class="lb">[</span> archive <span class="lb">/</span> previous ${rest.length} drops <span class="lb">]</span></span>
            <span class="m-label">one per day, via cron</span>
          </div>
          <div class="ia-grid">
            ${rest.map((post, i) => `
              <a href="${post.permalink}" target="_blank" rel="noopener noreferrer" class="ia-tile" aria-label="View post from ${fmtLong(post.timestamp)} on Instagram">
                <div class="ia-thumb"><img src="${srcOf(post)}" alt="" loading="lazy"></div>
                <div class="ia-tag">
                  <span>${String(i + 2).padStart(2, "0")}</span>
                  <span class="ia-date">${post.media_type === "VIDEO" ? "&#9654; " : ""}${fmtShort(post.timestamp)}</span>
                </div>
              </a>`).join("")}
          </div>
        </div>` : "";

      wrap.innerHTML = feature + archive;

      if (!reduced) {
        gsap.fromTo(wrap.querySelector(".insta-feature"),
          { opacity: 0, y: 24 },
          {
            opacity: 1, y: 0, duration: 0.6, ease: "power3.out",
            scrollTrigger: { trigger: wrap, start: "top 85%", once: true },
          }
        );
        const tiles = wrap.querySelectorAll(".ia-tile");
        if (tiles.length) {
          gsap.fromTo(tiles,
            { opacity: 0, y: 24 },
            {
              opacity: 1, y: 0,
              stagger: { amount: 0.5, from: "start" },
              duration: 0.5,
              ease: "power3.out",
              scrollTrigger: { trigger: ".insta-archive", start: "top 88%", once: true },
            }
          );
        }
      }
    } catch {
      wrap.innerHTML = `<p class="insta-status">couldn't load feed.</p>`;
    }
  }

  document.addEventListener("astro:page-load", initHeader);
  document.addEventListener("astro:page-load", initInstagramFeed);
</script>
