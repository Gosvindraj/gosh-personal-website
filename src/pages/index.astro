---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Gosvindraj | Home" description="Gosvindraj's personal portfolio. Developer in Penang building at the intersection of AI and blockchain." pageClass="home" hideFooter={true}>

  <div id="home-shell">

    <!-- ── hero ─────────────────────────────────── -->
    <section id="hero">
      <div class="hero-top">
        <span class="m-label"><span class="lb">[</span> portfolio <span class="hl">v3</span> <span class="lb">]</span></span>
        <span class="scroll-line" aria-hidden="true"></span>
        <span class="m-label">est. penang, my</span>
      </div>

      <div class="hero-main">
        <p class="hero-eyebrow">hi, i'm gosh.</p>
        <h1 class="hero-display display">
          <span class="sr-only">Gosvindraj, a developer in Penang building AI and blockchain projects.</span>
          <span class="line-mask" aria-hidden="true"><span class="line">i build</span></span>
          <span class="line-mask" aria-hidden="true"><span class="line"><span id="rot-word" class="acid">what's <br class="mobile-break" />next.</span></span></span>
        </h1>

        <div class="hero-foot">
          <p class="hero-bio">
            a dev poking at the edges of AI and blockchain. i don't
            wait for the tutorial: if it's new, i'm already breaking it
            to see how it works.
          </p>
          <div class="hero-cta-col">
            <div class="hero-cta">
              <a href="/projects" class="btn-solid btn-solid-invert">the work <span aria-hidden="true">&rarr;</span></a>
              <a href="/about" class="btn-solid btn-solid-invert">the story <span aria-hidden="true">&rarr;</span></a>
            </div>
            <a href="/contact" class="hero-sayhi m-label">
              <span class="lb">[</span> or, want to connect? say hi <span class="hl">&#8599;</span> <span class="lb">]</span>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-bottom">
        <span class="m-label">welcome</span>
        <span class="scroll-line" aria-hidden="true"></span>
        <span class="m-label">no cv energy beyond this point</span>
      </div>
    </section>

    <!-- ── ticker ───────────────────────────────── -->
    <p class="sr-only">Based in Penang, Malaysia. Breaks things before reading the docs. AI major, blockchain habit. Usually mid rabbit-hole. Open to collabs.</p>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[0, 1].map(() => (
          <div class="marquee-chunk">
            <span class="marquee-item"><span class="star">&#10035;</span> based in penang, malaysia</span>
            <span class="marquee-item"><span class="star">&#10035;</span> breaks things before reading the docs</span>
            <span class="marquee-item"><span class="star">&#10035;</span> AI major, blockchain habit</span>
            <span class="marquee-item"><span class="star">&#10035;</span> usually mid rabbit-hole</span>
            <span class="marquee-item"><span class="star">&#10035;</span> open to collabs</span>
          </div>
        ))}
      </div>
    </div>

  </div>

</BaseLayout>

<style>
  /* ── shell: hero + marquee fill exactly one viewport, on every
     screen size — #hero shrinks (flex:1, min-height:0) to share
     that fixed height with the marquee instead of each claiming
     a full viewport of its own, which is what pushed the mobile
     page past 100vh and forced a scrollbar. */
  #home-shell {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--nav-height));
  }

  /* ── hero ─────────────────────────────────── */
  #hero {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3vh, 2rem);
    padding: 1.1rem var(--gutter) 0.85rem;
    position: relative;
    overflow: hidden;
  }

  /* the middle .scroll-line is flex:1, so it fills whatever room is
     left and naturally pushes the two labels out to the edges —
     same trick .hero-bottom already uses */
  .hero-top {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  /* flex:1 + centering (rather than pinning to the top) splits
     whatever space #hero has left over evenly above and below this
     block, so the gap under the top bar matches the gap above the
     scroll indicator */
  .hero-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.1rem, 3.2vh, 2rem);
  }

  .hero-eyebrow {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.4rem, min(3vw, 4.6vh), 2.3rem);
    color: var(--dim);
    line-height: 1;
  }

  /* the size lever: bounded by width AND height so it can never
     outgrow the space left over once the shell is capped to one
     viewport on desktop. content now clusters near the top of #hero
     instead of being spread across it, so this can afford to run
     bigger than before without reintroducing the overflow */
  .hero-display {
    font-size: clamp(3.25rem, min(9vw, 17vh), 9.5rem);
    display: flex;
    flex-direction: column;
  }

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em;
    margin-bottom: -0.06em;
  }

  .line { display: block; }

  #rot-word { display: inline-block; }

  /* .rot-aside and .mobile-break are injected at runtime via
     rotWord.innerHTML, so they never receive Astro's scoping
     attribute — these rules must stay global or they silently stop
     matching after the first word rotation. */
  #rot-word :global(.rot-aside) { font-weight: 400; }

  /* forced breaks inside rotating words only apply on mobile, where
     some words would otherwise sit on one line and others wrap,
     shifting the layout below. on desktop there's always enough
     width, so these stay plain inline breaks (hidden). */
  #rot-word :global(.mobile-break) { display: none; }

  .hero-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-bio {
    max-width: 44ch;
    font-size: clamp(0.9rem, min(1.5vw, 2.2vh), 1.02rem);
    color: var(--dim);
    line-height: 1.8;
  }

  .hero-cta-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.85rem;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* inverse of .btn-solid: acid outline instead of acid fill, flips
     back to a solid fill on hover so the pair reads as complements */
  .btn-solid-invert {
    background: transparent;
    color: var(--acid);
  }

  .btn-solid-invert:hover {
    background: var(--acid);
    color: var(--bg);
  }

  /* a low-key "say hi" CTA at label scale, since the hero is
     already carrying the big display headline */
  .hero-sayhi {
    transition: color var(--transition);
  }

  .hero-sayhi .hl {
    display: inline-block;
    color: inherit;
    transition: transform var(--transition);
  }

  .hero-sayhi:hover { color: var(--acid); }
  .hero-sayhi:hover .hl { transform: translate(0.12em, -0.12em); }

  .hero-bottom {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  .scroll-line {
    flex: 1;
    height: 1px;
    background: var(--line);
    position: relative;
    overflow: hidden;
  }

  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: -20%;
    width: 20%;
    height: 100%;
    background: var(--acid);
  }

  /* one connected loop instead of two independent sweeps: run the
     top line left → right, jump to the bottom line, run that too,
     then repeat */
  .hero-top .scroll-line::after {
    animation: sweep-top 6s linear infinite;
  }

  .hero-bottom .scroll-line::after {
    animation: sweep-bottom 6s linear infinite;
  }

  @keyframes sweep-top {
    0%     { left: -20%; opacity: 1; }
    50%    { left: 100%; opacity: 1; }
    50.01% { opacity: 0; }
    100%   { opacity: 0; }
  }

  @keyframes sweep-bottom {
    0%     { left: 100%; opacity: 0; }
    49.99% { left: 100%; opacity: 0; }
    50%    { opacity: 1; }
    100%   { left: -20%; opacity: 1; }
  }

  @media (max-width: 700px) {
    .hero-top .m-label:last-child { display: none; }
    .hero-bottom .m-label:last-child { display: none; }
    .hero-cta-col { width: 100%; align-items: center; gap: 1.4rem; }
    .hero-cta { justify-content: center; }
    .hero-cta a { justify-content: center; padding: 0.8rem 1.6rem; }

    /* rotating words vary in length, and some wrap to two lines at
       this width while others fit on one. reserve room for the
       two-line case always so swapping words never shifts the
       content below (bio, buttons, marquee). */
    .hero-display .line-mask:last-of-type { min-height: 1.88em; }

    #rot-word :global(.mobile-break) { display: block; }
  }

  /* the marquee no longer scrolls in from below content — it's the
     literal bottom edge of the page on desktop */
  .marquee {
    flex-shrink: 0;
  }
</style>

<script>
  import gsap from "gsap";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const ROT_WORDS = [
    "what's <br class=\"mobile-break\" />next.",
    "ai <br class=\"mobile-break\" />workflows.",
    "onchain <br class=\"mobile-break\" />stuff.",
    "random <br class=\"mobile-break\" />apps.",
    "websites. <br class=\"mobile-break\" /><i class=\"rot-aside\">(like this)</i>",
  ];

  let rotTimer: ReturnType<typeof setInterval> | undefined;

  function initHero() {
    const hero = document.getElementById("hero");
    if (!hero) return;

    const lines   = hero.querySelectorAll<HTMLElement>(".line");
    const eyebrow = hero.querySelector<HTMLElement>(".hero-eyebrow");
    const foot    = hero.querySelector<HTMLElement>(".hero-foot");
    const top     = hero.querySelector<HTMLElement>(".hero-top");
    const bottom  = hero.querySelector<HTMLElement>(".hero-bottom");
    const rotWord = document.getElementById("rot-word");

    /* word rotator (skipped for reduced motion) */
    let rotIdx = 0;
    if (rotWord && !reduced) {
      rotTimer = setInterval(() => {
        rotIdx = (rotIdx + 1) % ROT_WORDS.length;
        gsap.timeline()
          .to(rotWord, { yPercent: -110, duration: 0.4, ease: "power3.in" })
          .add(() => { rotWord.innerHTML = ROT_WORDS[rotIdx]; })
          .set(rotWord, { yPercent: 110 })
          .to(rotWord, { yPercent: 0, duration: 0.5, ease: "power3.out" });
      }, 2600);

      document.addEventListener("astro:before-swap", () => {
        if (rotTimer) clearInterval(rotTimer);
      }, { once: true });
    }

    if (reduced) return;

    /* entrance: waits out the preloader on a fresh session */
    const delay = sessionStorage.getItem("intro-seen") ? 0.1 : 2.1;

    gsap.set([top, bottom], { opacity: 0 });
    gsap.set(eyebrow, { opacity: 0, y: 16 });
    gsap.set(foot, { opacity: 0, y: 20 });
    gsap.set(lines, { yPercent: 110 });

    gsap.timeline({ delay })
      .to(eyebrow, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" })
      .to(lines, { yPercent: 0, duration: 0.85, stagger: 0.12, ease: "power4.out" }, "-=0.25")
      .to(foot, { opacity: 1, y: 0, duration: 0.55, ease: "power3.out" }, "-=0.4")
      .to([top, bottom], { opacity: 1, duration: 0.5, ease: "power2.out" }, "-=0.3");
  }

  document.addEventListener("astro:page-load", initHero);
</script>
