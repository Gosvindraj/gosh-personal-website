---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Gosvindraj | Avalanche Anomaly Detector" description="Paste an Avalanche C-Chain wallet and an Isolation Forest model flags anomalous transactions by value, gas, and timing.">
  <section id="project-anomaly">
    <div class="project-inner">

      <!-- ── left panel ── -->
      <div class="project-header">
        <span class="m-label"><span class="lb">[</span> project <span class="hl">03</span> <span class="lb">]</span></span>
        <h1 class="project-title display">anomaly<br />detector<span class="serif acid">.</span></h1>
        <p class="project-desc">
          paste an Avalanche C-Chain wallet address to analyze its recent
          transactions for anomalous behaviour. detection runs server-side
          using an Isolation Forest model on value, gas, and timing patterns.
        </p>

        <div class="legend">
          <div class="legend-item"><span class="dot dot-normal"></span>normal</div>
          <div class="legend-item"><span class="dot dot-suspicious"></span>suspicious</div>
          <div class="legend-item"><span class="dot dot-anomalous"></span>anomalous</div>
        </div>

        <a href="/projects" class="back-link m-label">&larr; all projects</a>
      </div>

      <!-- ── right panel ── -->
      <div class="anomaly-wrap">

        <div class="input-row">
          <input
            type="text"
            id="address-input"
            placeholder="0x... Avalanche C-Chain address"
            spellcheck="false"
            autocomplete="off"
            maxlength="42"
          />
          <button id="analyze-btn" type="button" data-magnetic>
            <span id="btn-text">analyze</span>
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>

        <p class="info-msg" id="info-msg"></p>

        <div id="results" class="hidden">
          <div class="summary" id="summary"></div>
          <div class="table-wrap">
            <table id="tx-table">
              <thead>
                <tr>
                  <th>Hash</th>
                  <th>Time</th>
                  <th>Value</th>
                  <th>Gas</th>
                  <th>Score</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="tx-body"></tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── modal ── -->
  <div id="tx-modal" class="modal-backdrop hidden" aria-modal="true" role="dialog">
    <div class="modal-panel" id="modal-panel">
      <button class="modal-close" id="modal-close" aria-label="Close">
        <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <div class="modal-header">
        <div class="modal-flag-row">
          <span class="modal-badge" id="modal-badge"></span>
          <span class="modal-score" id="modal-score"></span>
        </div>
        <div class="modal-hash-row">
          <span class="modal-hash-val" id="modal-hash-display"></span>
          <div class="modal-hash-actions">
            <button class="icon-btn" id="modal-copy" title="Copy hash">
              <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="11" height="11" rx="1"/><path d="M5 15V5a1 1 0 0 1 1-1h10"/></svg>
            </button>
            <a class="icon-btn" id="modal-snowtrace" href="#" target="_blank" rel="noopener" title="View on Snowtrace">
              <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="8 7 17 7 17 16"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="modal-meta" id="modal-meta"></div>

      <div class="modal-divider"></div>

      <div class="modal-verdict" id="modal-verdict"></div>

      <div class="modal-features" id="modal-features"></div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  #project-anomaly {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: flex-start;
    padding: clamp(2.5rem, 6vh, 4rem) var(--gutter);
  }

  #project-anomaly .project-inner {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: clamp(2.5rem, 6vw, 5rem);
  }

  /* ── left panel ── */
  #project-anomaly .project-header {
    flex: 0 0 300px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    opacity: 0;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  #project-anomaly .project-title { font-size: clamp(2rem, 4.4vw, 3.4rem); }

  #project-anomaly .project-desc {
    font-size: 0.88rem;
    color: var(--dim);
    line-height: 1.9;
  }

  #project-anomaly .back-link {
    align-self: flex-start;
    transition: color var(--transition);
  }

  #project-anomaly .back-link:hover { color: var(--acid); }

  .legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .dot {
    width: 7px;
    height: 7px;
    flex-shrink: 0;
  }

  .dot-normal     { background: var(--ok); }
  .dot-suspicious { background: var(--warn); }
  .dot-anomalous  { background: var(--bad); }

  /* ── right panel ── */
  .anomaly-wrap {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 0;
  }

  .input-row {
    display: flex;
    gap: 0;
    border: 1px solid var(--line);
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .input-row:focus-within { border-color: var(--acid); }

  #address-input {
    flex: 1;
    background: var(--surface);
    border: none;
    outline: none;
    padding: 0.9rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    letter-spacing: 0.04em;
    min-width: 0;
    cursor: none;
  }

  #address-input::placeholder {
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }

  #analyze-btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--acid);
    border: none;
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.9rem 1.5rem;
    transition: background var(--transition);
    white-space: nowrap;
    will-change: transform;
  }

  #analyze-btn svg { transition: transform var(--transition); }
  #analyze-btn:hover { background: #d9fb70; }
  #analyze-btn:hover svg { transform: translateX(3px); }
  #analyze-btn:disabled { opacity: 0.4; pointer-events: none; }

  .info-msg {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--dim);
    letter-spacing: 0.04em;
    min-height: 1.2em;
  }

  .info-msg.error { color: var(--bad); }

  /* ── summary ── */
  .summary {
    display: flex;
    gap: 2.5rem;
    padding: 1.1rem 0 1.4rem;
    border-top: 1px solid var(--line-strong);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .stat-val {
    font-family: var(--font-sans);
    font-stretch: 112%;
    font-weight: 740;
    font-size: 1.8rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
  }

  .stat-val.has-anomalies  { color: var(--bad); }
  .stat-val.has-suspicious { color: var(--warn); }

  /* ── table ── */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line-strong);
  }

  #tx-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }

  #tx-table th {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    text-align: left;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--line-strong);
    white-space: nowrap;
    background: var(--surface);
  }

  #tx-table th:last-child { width: 32px; }

  .tx-row {
    cursor: none;
    transition: background var(--transition);
    position: relative;
  }

  .tx-row td {
    padding: 1.3rem 1.5rem;
    border-bottom: 1px solid var(--line);
    color: var(--dim);
    vertical-align: middle;
    white-space: nowrap;
    transition: background var(--transition), color var(--transition);
  }

  .tx-row:hover td {
    background: var(--acid-dim);
    color: var(--ink);
  }

  .tx-row:hover td:first-child {
    box-shadow: inset 2px 0 0 var(--acid);
  }

  .tx-row:hover .row-arrow { opacity: 1; transform: translateX(2px); }

  .td-hash a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--acid);
    letter-spacing: 0.03em;
    cursor: none;
    transition: opacity var(--transition);
  }

  .td-hash a:hover { opacity: 0.7; }

  .td-value { font-family: var(--font-mono); color: var(--ink); }

  /* score bar */
  .score-wrap { display: flex; align-items: center; gap: 0.5rem; }

  .score-bar-bg {
    width: 60px;
    height: 4px;
    background: var(--line);
    overflow: hidden;
    flex-shrink: 0;
  }

  .score-bar-fill { height: 100%; }

  .score-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--dim);
    min-width: 36px;
  }

  /* status badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
  }

  .badge-dot { width: 5px; height: 5px; }

  .badge-normal     { background: rgba(var(--ok-rgb), 0.1); color: var(--ok); }
  .badge-normal     .badge-dot { background: var(--ok); }
  .badge-suspicious { background: rgba(var(--warn-rgb), 0.1);  color: var(--warn); }
  .badge-suspicious .badge-dot { background: var(--warn); }
  .badge-anomalous  { background: rgba(var(--bad-rgb), 0.1);   color: var(--bad); }
  .badge-anomalous  .badge-dot { background: var(--bad); }

  /* row arrow hint */
  .row-arrow {
    color: var(--dim);
    font-size: 10px;
    opacity: 0;
    transition: opacity var(--transition), transform var(--transition);
  }

  .hidden { display: none !important; }

  /* ── modal ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .modal-panel {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--line-strong);
    border-top: 1px solid var(--acid);
    width: 100%;
    max-width: 540px;
    max-height: 88vh;
    overflow-y: auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--line);
    color: var(--dim);
    font-size: 12px;
    cursor: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .modal-close:hover { color: var(--ink); border-color: var(--line-strong); background: var(--surface); }

  /* modal header */
  .modal-header { display: flex; flex-direction: column; gap: 0.6rem; }

  .modal-flag-row { display: flex; align-items: center; gap: 0.75rem; }

  .modal-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
  }

  .modal-score {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--dim);
  }

  .modal-hash-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .modal-hash-val {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink);
    letter-spacing: 0.03em;
    word-break: break-all;
    flex: 1;
    min-width: 0;
  }

  .modal-hash-actions { display: flex; gap: 0.4rem; flex-shrink: 0; }

  .icon-btn {
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--line);
    color: var(--dim);
    font-size: 11px;
    cursor: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
    text-decoration: none;
  }

  .icon-btn:hover { color: var(--ink); border-color: var(--line-strong); background: var(--surface); }

  /* modal meta */
  .modal-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem 1.5rem;
  }

  .meta-item { display: flex; flex-direction: column; gap: 0.3rem; }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .meta-val {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink);
    word-break: break-all;
  }

  .modal-divider {
    height: 1px;
    background: var(--line);
  }

  /* verdict */
  .modal-verdict {
    font-size: 0.85rem;
    color: var(--dim);
    line-height: 1.9;
    border-left: 2px solid var(--acid);
    padding-left: 1rem;
  }

  /* feature bars */
  .modal-features {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .features-heading {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    opacity: 0.6;
  }

  .feature-block { display: flex; flex-direction: column; gap: 0.4rem; }

  .feature-top-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .feature-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dim);
  }

  .feature-pct {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink);
    opacity: 0.7;
  }

  .feature-track {
    width: 100%;
    height: 5px;
    background: var(--line);
    overflow: hidden;
  }

  .feature-fill {
    height: 100%;
    opacity: 0.8;
    transition: width 0.5s ease;
  }

  @media (max-width: 960px) {
    /* align-items:flex-start is meant for the desktop row layout
       (top-align the two columns); in column mode it instead
       controls the horizontal axis, letting .anomaly-wrap shrink
       to its content's natural (unwrapped) width and overflow past
       the right edge instead of filling the viewport */
    #project-anomaly .project-inner { flex-direction: column; align-items: stretch; gap: 3rem; }
    #project-anomaly .project-header { flex: none; position: static; }
  }

  @media (max-width: 600px) {
    .modal-meta { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from "gsap";

  interface FeatureStat { raw: number; pct: number; }

  interface TxResult {
    hash: string;
    timestamp: number;
    from: string;
    to: string | null;
    valueAvax: number;
    gasUsed: number;
    score: number;
    flag: "normal" | "suspicious" | "anomalous";
    features: {
      value:     FeatureStat;
      gas:       FeatureStat;
      timeDelta: FeatureStat;
    };
  }

  function timeAgo(ts: number): string {
    const diff = Math.floor(Date.now() / 1000) - ts;
    if (diff < 60)    return `${diff}s ago`;
    if (diff < 3600)  return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    return `${Math.floor(diff / 86400)}d ago`;
  }

  function fmtDate(ts: number): string {
    return new Date(ts * 1000).toLocaleString("en-US", {
      month: "short", day: "numeric", year: "numeric",
      hour: "2-digit", minute: "2-digit",
    });
  }

  function fmtAvax(v: number): string {
    if (v === 0)    return "0 AVAX";
    if (v < 0.0001) return "<0.0001 AVAX";
    return `${v.toLocaleString("en-US", { maximumFractionDigits: 4 })} AVAX`;
  }

  function scoreColor(flag: string): string {
    if (flag === "anomalous")  return "var(--bad)";
    if (flag === "suspicious") return "var(--warn)";
    return "var(--ok)";
  }

  function truncate(addr: string, head = 8, tail = 6): string {
    if (!addr) return "-";
    return `${addr.slice(0, head)}...${addr.slice(-tail)}`;
  }

  function explain(tx: TxResult): string {
    const { value, gas, timeDelta } = tx.features;
    const lines: string[] = [];

    if (tx.flag === "normal") {
      lines.push("This transaction fits within the wallet's typical activity pattern.");
    } else {
      lines.push(
        tx.flag === "anomalous"
          ? "This transaction stands out significantly from the wallet's typical behaviour."
          : "This transaction shows some unusual characteristics."
      );
    }

    if (value.pct >= 90)
      lines.push(`Value of ${fmtAvax(value.raw)} is higher than ${value.pct}% of this wallet's transactions. Unusually large.`);
    else if (value.pct <= 10 && value.raw === 0)
      lines.push(`Zero AVAX transferred, likely a contract interaction or token swap.`);
    else if (value.pct <= 10)
      lines.push(`Value of ${fmtAvax(value.raw)} is lower than ${100 - value.pct}% of this wallet's transactions.`);

    if (gas.pct >= 90)
      lines.push(`Gas used (${gas.raw.toLocaleString()}) is higher than ${gas.pct}% of transactions, indicating a complex contract execution.`);
    else if (gas.pct <= 10)
      lines.push(`Gas used (${gas.raw.toLocaleString()}) is very low, typical of a simple transfer.`);

    if (timeDelta.raw === 0) {
      lines.push(`First transaction in the analyzed set, no prior timing reference.`);
    } else if (timeDelta.pct <= 5) {
      const secs = timeDelta.raw;
      lines.push(`Sent only ${secs < 60 ? secs + "s" : Math.round(secs / 60) + "m"} after the previous transaction, unusually rapid succession for this wallet.`);
    } else if (timeDelta.pct >= 90) {
      const hrs = Math.round(timeDelta.raw / 3600);
      lines.push(`Over ${hrs}h gap since the previous transaction, longer dormancy than usual for this wallet.`);
    }

    return lines.join(" ");
  }

  // ── modal ──────────────────────────────────────────────────────────────────

  let modalOpen = false;

  function openModal(tx: TxResult) {
    const backdrop   = document.getElementById("tx-modal")!;
    const panel      = document.getElementById("modal-panel")!;
    const badge      = document.getElementById("modal-badge")!;
    const scoreEl    = document.getElementById("modal-score")!;
    const hashDisp   = document.getElementById("modal-hash-display")!;
    const copyBtn    = document.getElementById("modal-copy")!;
    const snowtrace  = document.getElementById("modal-snowtrace") as HTMLAnchorElement;
    const metaEl     = document.getElementById("modal-meta")!;
    const verdictEl  = document.getElementById("modal-verdict")!;
    const featuresEl = document.getElementById("modal-features")!;

    const color = scoreColor(tx.flag);

    // badge
    badge.className = `modal-badge badge-${tx.flag}`;
    badge.innerHTML = `<span class="badge-dot"></span>${tx.flag}`;

    // score
    scoreEl.textContent = `score ${tx.score.toFixed(3)}`;

    // hash
    hashDisp.textContent = tx.hash;
    snowtrace.href = `https://snowtrace.io/tx/${tx.hash}`;

    // copy
    const COPY_ICON = `<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="11" height="11" rx="1"/><path d="M5 15V5a1 1 0 0 1 1-1h10"/></svg>`;
    const CHECK_ICON = `<svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    copyBtn.onclick = () => {
      navigator.clipboard.writeText(tx.hash).then(() => {
        copyBtn.innerHTML = CHECK_ICON;
        setTimeout(() => { copyBtn.innerHTML = COPY_ICON; }, 1500);
      });
    };

    // meta grid
    metaEl.innerHTML = `
      <div class="meta-item">
        <span class="meta-label">Time</span>
        <span class="meta-val">${fmtDate(tx.timestamp)}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Value</span>
        <span class="meta-val" style="color:${color}">${fmtAvax(tx.valueAvax)}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">From</span>
        <span class="meta-val" title="${tx.from}">${truncate(tx.from)}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">To</span>
        <span class="meta-val" title="${tx.to ?? ''}">${tx.to ? truncate(tx.to) : '-'}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Gas used</span>
        <span class="meta-val">${tx.gasUsed.toLocaleString()}</span>
      </div>
    `;

    // verdict
    verdictEl.textContent = explain(tx);

    // feature bars
    const { value, gas, timeDelta } = tx.features;
    featuresEl.innerHTML = `<span class="features-heading">Signal breakdown</span>` + [
      ["Value",    value.pct],
      ["Gas used", gas.pct],
      ["Time gap", timeDelta.pct],
    ].map(([label, pct]) => `
      <div class="feature-block">
        <div class="feature-top-row">
          <span class="feature-label">${label}</span>
          <span class="feature-pct">${pct}th percentile</span>
        </div>
        <div class="feature-track">
          <div class="feature-fill" style="width:${pct}%; background:${color}"></div>
        </div>
      </div>
    `).join("");

    // show
    backdrop.classList.remove("hidden");
    panel.scrollTop = 0;
    modalOpen = true;
    gsap.fromTo(panel, { opacity: 0, scale: 0.96, y: 12 }, { opacity: 1, scale: 1, y: 0, duration: 0.3, ease: "power3.out" });
  }

  function closeModal() {
    const backdrop = document.getElementById("tx-modal")!;
    const panel    = document.getElementById("modal-panel")!;
    gsap.to(panel, {
      opacity: 0, scale: 0.96, y: 8, duration: 0.2, ease: "power2.in",
      onComplete: () => { backdrop.classList.add("hidden"); modalOpen = false; },
    });
  }

  // ── results render ─────────────────────────────────────────────────────────

  function renderResults(txs: TxResult[]) {
    const results = document.getElementById("results")!;
    const summary = document.getElementById("summary")!;
    const tbody   = document.getElementById("tx-body")!;

    const total      = txs.length;
    const anomalous  = txs.filter(t => t.flag === "anomalous").length;
    const suspicious = txs.filter(t => t.flag === "suspicious").length;

    summary.innerHTML = `
      <div class="stat">
        <span class="stat-label">Analyzed</span>
        <span class="stat-val">${total}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Anomalous</span>
        <span class="stat-val ${anomalous > 0 ? "has-anomalies" : ""}">${anomalous}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Suspicious</span>
        <span class="stat-val ${suspicious > 0 ? "has-suspicious" : ""}">${suspicious}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Normal</span>
        <span class="stat-val">${total - anomalous - suspicious}</span>
      </div>
    `;

    tbody.innerHTML = txs.map((tx, i) => {
      const short = `${tx.hash.slice(0, 8)}...${tx.hash.slice(-6)}`;
      const color = scoreColor(tx.flag);
      const barW  = Math.round(tx.score * 100);
      return `
        <tr class="tx-row" data-idx="${i}">
          <td class="td-hash">
            <a href="https://snowtrace.io/tx/${tx.hash}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${short}</a>
          </td>
          <td>${timeAgo(tx.timestamp)}</td>
          <td class="td-value">${fmtAvax(tx.valueAvax)}</td>
          <td>${tx.gasUsed.toLocaleString()}</td>
          <td>
            <div class="score-wrap">
              <div class="score-bar-bg">
                <div class="score-bar-fill" style="width:${barW}%; background:${color}"></div>
              </div>
              <span class="score-num">${tx.score.toFixed(3)}</span>
            </div>
          </td>
          <td>
            <span class="badge badge-${tx.flag}">
              <span class="badge-dot"></span>${tx.flag}
            </span>
          </td>
          <td><svg aria-hidden="true" class="row-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></td>
        </tr>
      `;
    }).join("");

    // attach click to open modal
    tbody.querySelectorAll<HTMLElement>(".tx-row").forEach(row => {
      row.addEventListener("click", () => {
        const idx = Number(row.dataset.idx);
        openModal(txs[idx]);
      });
    });

    results.classList.remove("hidden");
    gsap.fromTo(results, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.4, ease: "power3.out" });
  }

  // ── init ───────────────────────────────────────────────────────────────────

  function initAnomaly() {
    const header = document.querySelector<HTMLElement>("#project-anomaly .project-header");
    const wrap   = document.querySelector<HTMLElement>(".anomaly-wrap");
    if (!header) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      gsap.set([header, wrap], { opacity: 1 });
    } else {
      gsap.fromTo(header, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out", delay: 0.1 });
      gsap.fromTo(wrap,   { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out", delay: 0.25 });
    }

    const input   = document.getElementById("address-input") as HTMLInputElement;
    const btn     = document.getElementById("analyze-btn")   as HTMLButtonElement;
    const btnText = document.getElementById("btn-text")      as HTMLElement;
    const infoMsg = document.getElementById("info-msg")      as HTMLElement;
    const results = document.getElementById("results")       as HTMLElement;

    // modal close
    document.getElementById("modal-close")!.addEventListener("click", closeModal);
    document.getElementById("tx-modal")!.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modalOpen) closeModal();
    });

    function setInfo(msg: string, isError = false) {
      infoMsg.textContent = msg;
      infoMsg.className   = "info-msg" + (isError ? " error" : "");
    }

    btn.addEventListener("click", async () => {
      const address = input.value.trim();

      if (!/^0x[0-9a-fA-F]{40}$/.test(address)) {
        setInfo("Enter a valid 0x Avalanche C-Chain address.", true);
        return;
      }

      btn.disabled = true;
      btnText.textContent = "analyzing...";
      results.classList.add("hidden");
      setInfo("fetching transactions from Glacier API...");

      try {
        const res = await fetch("/api/anomaly", {
          method:  "POST",
          headers: { "Content-Type": "application/json" },
          body:    JSON.stringify({ address }),
        });

        const data = await res.json() as {
          transactions?: TxResult[];
          message?: string;
          error?: string;
        };

        if (!res.ok || data.error) {
          setInfo(data.error ?? "Something went wrong. Please try again.", true);
          return;
        }

        if (!data.transactions?.length) {
          setInfo(data.message ?? "No transactions found.", false);
          return;
        }

        setInfo(`${data.transactions.length} transactions analyzed. Click any row to inspect.`);
        renderResults(data.transactions);

      } catch {
        setInfo("Network error. Please try again.", true);
      } finally {
        btn.disabled = false;
        btnText.textContent = "analyze";
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") btn.click();
    });

    // magnetic button
    btn.addEventListener("mousemove", (e) => {
      const rect = btn.getBoundingClientRect();
      gsap.to(btn, {
        x: (e.clientX - rect.left - rect.width  / 2) * 0.35,
        y: (e.clientY - rect.top  - rect.height / 2) * 0.35,
        duration: 0.3, ease: "power2.out",
      });
    });
    btn.addEventListener("mouseleave", () => {
      gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: "elastic.out(1,0.5)" });
    });
  }

  document.addEventListener("astro:page-load", initAnomaly);
</script>
